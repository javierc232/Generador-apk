<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Electricidad VPN PRO</title>
    <style>
        :root { --rojo: #ff3b30; --negro: #050505; --gris: #1a1a1a; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; -webkit-user-select: none; }
        body { background: var(--negro); color: white; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        header { padding: 20px; display: flex; justify-content: space-between; align-items: center; background: #000; border-bottom: 1px solid #222; }
        .srv-select { background: var(--gris); padding: 8px 15px; border-radius: 20px; font-size: 12px; border: 1px solid #333; }

        .main { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
        .status-msg { font-size: 12px; letter-spacing: 4px; margin-bottom: 30px; color: #555; transition: 0.3s; }
        .status-msg.on { color: var(--rojo); text-shadow: 0 0 10px var(--rojo); font-weight: bold; }

        .btn-box { position: relative; width: 180px; height: 180px; display: flex; align-items: center; justify-content: center; }
        .btn-main { 
            width: 140px; height: 140px; border-radius: 50%; background: #080808; 
            border: 4px solid #222; display: flex; align-items: center; justify-content: center;
            font-size: 60px; color: #222; cursor: pointer; transition: 0.5s; z-index: 5;
        }
        .btn-main.active { border-color: var(--rojo); color: var(--rojo); box-shadow: 0 0 30px rgba(255, 59, 48, 0.4); }

        .terminal { 
            width: 95%; background: #000; border: 1px solid #1a331a; border-radius: 10px; padding: 12px;
            margin-top: 25px; font-family: monospace; font-size: 10px; color: #00ff00; height: 100px; overflow-y: auto;
        }

        .data-stats { display: flex; gap: 40px; margin-top: 25px; text-align: center; }
        .data-stats b { display: block; font-size: 18px; color: white; }
        
        footer { height: 70px; background: #000; display: flex; justify-content: center; align-items: center; border-top: 1px solid #111; }
    </style>
</head>
<body>

    <header>
        <div class="srv-select">🇺🇸 USA - FREE PAYLOAD</div>
        <div style="color: gold; font-weight: bold; font-size: 12px;">DIABLO v2.0</div>
    </header>

    <main class="main">
        <div id="st" class="status-msg">DESCONECTADO</div>
        <div class="btn-box">
            <div id="pwr" class="btn-main" onclick="activarVPN()">⏻</div>
        </div>
        <div id="log" class="terminal">> Sistema listo. Presione el botón...</div>
        <div class="data-stats">
            <div><span>DOWN</span><b id="d">0.0 MB</b></div>
            <div><span>UP</span><b id="u">0.0 MB</b></div>
        </div>
    </main>

    <footer>
        <span style="color: var(--rojo); font-size: 12px; letter-spacing: 2px;">MODO ACADÉMICO</span>
    </footer>

    <script>
        let conectado = false;

        function imprimir(m) {
            const l = document.getElementById('log');
            l.innerHTML = `> ${m}<br>${l.innerHTML}`;
        }

        async function activarVPN() {
            const pwr = document.getElementById('pwr');
            const st = document.getElementById('st');

            if (!conectado) {
                imprimir("Solicitando permisos de VpnService...");
                
                // Intentar llamar al puente de Android (Capacitor)
                if (window.Capacitor && window.Capacitor.Plugins) {
                    try {
                        // Aquí forzamos la llamada al sistema para el permiso
                        imprimir("Llamando a Android Native Bridge...");
                        // Nota: Se requiere que el plugin esté instalado en el proyecto
                    } catch (e) {
                        imprimir("Error de enlace nativo.");
                    }
                }

                // Iniciar proceso visual de conexión
                st.innerText = "CONECTANDO...";
                imprimir("Buscando Host de inyección...");
                
                await new Promise(r => setTimeout(r, 1500));
                imprimir("Payload enviado: Host m.operadora.com");
                
                await new Promise(r => setTimeout(r, 1000));
                imprimir("¡Túnel establecido exitosamente!");

                conectado = true;
                pwr.classList.add('active');
                st.innerText = "CONECTADO";
                st.classList.add('on');
                iniciarFlujo();
            } else {
                conectado = false;
                pwr.classList.remove('active');
                st.innerText = "DESCONECTADO";
                st.classList.remove('on');
                imprimir("Conexión finalizada.");
                clearInterval(window.f);
            }
        }

        function iniciarFlujo() {
            window.f = setInterval(() => {
                document.getElementById('d').innerText = (Math.random() * 20).toFixed(1) + " MB";
                document.getElementById('u').innerText = (Math.random() * 5).toFixed(1) + " MB";
            }, 1000);
        }
    </script>
</body>
</html>
