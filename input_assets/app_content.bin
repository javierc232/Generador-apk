<!-- Reemplaza todo tu código HTML con este mejorado -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebForge Pro — Constructor Real</title>
    <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;600;700&family=Cabinet+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --ink: #050508; --ink2: #0f0f15; --ink3: #1a1a24; --border: rgba(255,255,255,0.1); --lime: #c8f135; --blue: #3d8ef8; --white: #f0f0f5; --muted: #6b6b85; }
        body { background: var(--ink); color: var(--white); font-family: 'Cabinet Grotesk', sans-serif; margin: 0; overflow-x: hidden; }
        .screen { display: none; min-height: 100vh; flex-direction: column; }
        .screen.active { display: flex; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .navbar { height: 64px; background: var(--ink2); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 20px; position: sticky; top: 0; z-index: 100; }
        .logo { font-family: 'Clash Display'; font-weight: 700; font-size: 20px; }
        .logo span { color: var(--lime); }
        .main-layout { display: flex; flex-direction: column; }
        @media(min-width: 900px) { .main-layout { display: grid; grid-template-columns: 400px 1fr; height: calc(100vh - 64px); } }
        .config-panel { padding: 20px; background: var(--ink2); border-right: 1px solid var(--border); overflow-y: auto; }
        .section { margin-bottom: 25px; }
        label { display: block; font-size: 11px; text-transform: uppercase; font-weight: 700; color: var(--muted); margin-bottom: 8px; }
        input, select { width: 100%; background: var(--ink3); border: 1px solid var(--border); padding: 12px; border-radius: 8px; color: white; box-sizing: border-box; outline: none; }
        .icon-upload { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
        .icon-preview { width: 60px; height: 60px; background: var(--ink3); border: 1px solid var(--border); border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .icon-preview img { width: 100%; height: 100%; object-fit: cover; }
        .btn { padding: 12px 20px; border-radius: 8px; font-weight: 700; cursor: pointer; border: none; transition: 0.2s; text-align: center; }
        .btn-lime { background: var(--lime); color: var(--ink); width: 100%; }
        .btn-ghost { background: transparent; color: white; border: 1px solid var(--border); font-size: 12px; }
        .tabs { display: flex; background: var(--ink); padding: 4px; border-radius: 10px; margin-bottom: 15px; }
        .tab { flex: 1; padding: 10px; text-align: center; font-size: 13px; cursor: pointer; border-radius: 6px; color: var(--muted); }
        .tab.active { background: var(--ink3); color: var(--lime); }
        .preview-panel { background: #08080a; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
        .phone-shell { background: #111; border-radius: 35px; border: 8px solid #222; overflow: hidden; position: relative; box-shadow: 0 30px 60px rgba(0,0,0,0.5); width: 280px; height: 550px; }
        .phone-screen { width: 100%; height: 100%; background: white; display: flex; flex-direction: column; }
        .app-bar { height: 55px; background: var(--blue); color: white; display: flex; align-items: center; padding: 0 15px; font-weight: 600; }
        #screen-generating { background: var(--ink); justify-content: center; align-items: center; text-align: center; padding: 20px; }
        .loader { width: 60px; height: 60px; border: 5px solid var(--ink3); border-top: 5px solid var(--lime); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <div class="screen active" id="screen-builder">
        <nav class="navbar">
            <div class="logo">WEB<span>FORGE</span> PRO</div>
            <div style="display: flex; gap: 8px;">
                <button class="btn btn-ghost" onclick="toggleSettings()">⚙️ Config</button>
                <button class="btn btn-lime" onclick="generateApp()">GENERAR APK REAL</button>
            </div>
        </nav>

        <div class="main-layout">
            <aside class="config-panel">
                <div id="github-settings" style="display:none; background: rgba(200,241,53,0.05); padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid var(--lime);">
                    <label>GitHub Token</label>
                    <input type="password" id="gh-token" placeholder="ghp_xxxxxxxx">
                    <label style="margin-top:10px;">Usuario / Repo</label>
                    <div style="display:flex; gap:5px">
                        <input type="text" id="gh-user" value="javierc232">
                        <input type="text" id="gh-repo" value="Generador-apk">
                    </div>
                </div>

                <div class="section">
                    <label>Logo e Identidad</label>
                    <div class="icon-upload">
                        <div class="icon-preview" id="icon-preview">📱</div>
                        <div style="flex:1">
                            <button class="btn btn-ghost" style="width:100%" onclick="document.getElementById('icon-input').click()">Subir Logo</button>
                            <input type="file" id="icon-input" hidden accept="image/*" onchange="handleIcon(this)">
                        </div>
                    </div>
                    <input type="text" id="app-name" placeholder="Nombre de la App">
                </div>

                <div class="section">
                    <label>Package ID</label>
                    <input type="text" id="app-package" placeholder="com.myapp.test">
                </div>

                <div class="section">
                    <label>Contenido</label>
                    <div class="tabs">
                        <div class="tab active" id="tab-url" onclick="setSource('url')">URL</div>
                        <div class="tab" id="tab-file" onclick="setSource('file')">HTML/ZIP</div>
                    </div>
                    <div id="source-url"><input type="url" id="app-url" placeholder="https://sitio.com"></div>
                    <div id="source-file" style="display:none;">
                        <button class="btn btn-ghost" style="width:100%" onclick="document.getElementById('file-input').click()" id="file-btn">📁 Subir Archivo (ZIP/HTML)</button>
                        <input type="file" id="file-input" hidden accept=".html,.zip" onchange="handleFile(this)">
                    </div>
                </div>
            </aside>

            <main class="preview-panel">
                <div class="phone-shell">
                    <div class="phone-screen">
                        <div class="app-bar" id="preview-bar">Vista Previa</div>
                        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#f9f9f9; color:#999; text-align:center; padding: 20px;">
                            📱<br>Listo para compilar
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div class="screen" id="screen-generating">
        <div class="loader"></div>
        <h2 id="gen-title">Iniciando transferencia...</h2>
        <p id="gen-info" style="color:var(--muted); font-size:12px;">Subiendo archivos al repositorio para bypass de límite de tamaño.</p>
    </div>

    <script>
        let state = { source: 'url', fileBase64: null, iconBase64: null, fileName: "" };

        function toggleSettings() { const s = document.getElementById('github-settings'); s.style.display = s.style.display === 'none' ? 'block' : 'none'; }
        function setSource(src) { state.source = src; document.getElementById('tab-url').className = src === 'url' ? 'tab active' : 'tab'; document.getElementById('tab-file').className = src === 'file' ? 'tab active' : 'tab'; document.getElementById('source-url').style.display = src === 'url' ? 'block' : 'none'; document.getElementById('source-file').style.display = src === 'file' ? 'block' : 'none'; }
        
        function handleIcon(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        canvas.width = 96; canvas.height = 96;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, 96, 96);
                        state.iconBase64 = canvas.toDataURL('image/png').split(',')[1];
                        document.getElementById('icon-preview').innerHTML = `<img src="${canvas.toDataURL()}">`;
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        }

        function handleFile(input) {
            const file = input.files[0];
            if (file) {
                state.fileName = file.name;
                document.getElementById('file-btn').innerText = "✅ " + file.name;
                const reader = new FileReader();
                reader.onload = (e) => { state.fileBase64 = e.target.result.split(',')[1]; };
                reader.readAsDataURL(file);
            }
        }

        // --- LA FUNCIÓN MÁGICA: SUBIR A GITHUB CONTENT API ---
        async function uploadFileToRepo(token, user, repo, path, contentBase64) {
            // Primero intentamos obtener el SHA si el archivo ya existe (para poder sobrescribirlo)
            let sha = "";
            try {
                const res = await fetch(`https://api.github.com/repos/${user}/${repo}/contents/${path}`, {
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (res.ok) { const data = await res.json(); sha = data.sha; }
            } catch (e) {}

            const res = await fetch(`https://api.github.com/repos/${user}/${repo}/contents/${path}`, {
                method: "PUT",
                headers: { "Authorization": `Bearer ${token}`, "Content-Type": "application/json" },
                body: JSON.stringify({
                    message: "Upload app resources from WebForge",
                    content: contentBase64,
                    sha: sha
                })
            });
            return res.ok;
        }

        async function generateApp() {
            const token = document.getElementById('gh-token').value;
            const name = document.getElementById('app-name').value;
            const pkg = document.getElementById('app-package').value;
            const user = document.getElementById('gh-user').value;
            const repo = document.getElementById('gh-repo').value;

            if(!token || !name) { alert("Completa los datos."); return; }

            document.getElementById('screen-builder').classList.remove('active');
            document.getElementById('screen-generating').classList.add('active');

            try {
                // 1. Subir Contenido (Si es archivo)
                if (state.source === 'file' && state.fileBase64) {
                    document.getElementById('gen-title').innerText = "Subiendo HTML/ZIP...";
                    await uploadFileToRepo(token, user, repo, "input_assets/app_content.bin", state.fileBase64);
                }

                // 2. Subir Icono
                if (state.iconBase64) {
                    document.getElementById('gen-title').innerText = "Subiendo Icono...";
                    await uploadFileToRepo(token, user, repo, "input_assets/icon.png", state.iconBase64);
                }

                // 3. Disparar compilación (Payload ahora es muy pequeño, solo texto)
                document.getElementById('gen-title').innerText = "Iniciando compilación...";
                const payload = {
                    event_type: "build_app",
                    client_payload: {
                        app_name: name, package_id: pkg || "com.webforge.app",
                        primary_color: document.getElementById('app-color').value,
                        source_type: state.source,
                        file_ext: state.fileName.split('.').pop()
                    }
                };

                const response = await fetch(`https://api.github.com/repos/${user}/${repo}/dispatches`, {
                    method: "POST",
                    headers: { "Authorization": `Bearer ${token}` },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    document.getElementById('gen-title').innerText = "🚀 ¡Éxito!";
                    alert("¡Archivos subidos! GitHub ya no tiene el límite de 64KB. Tu APK estará lista en 3 min.");
                    location.reload();
                } else { alert("Error al disparar."); location.reload(); }
            } catch (e) { alert("Falla técnica."); location.reload(); }
        }
    </script>
</body>
</html>