<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electricidad</title>
    <style>
        /* Aquí va tu diseño */
        body { background: #050505; color: #00ff00; font-family: monospace; text-align: center; }
        .btn { 
            width: 100px; height: 100px; border-radius: 50%; border: 2px solid #ff3131;
            background: none; color: #ff3131; font-weight: bold; cursor: pointer;
            margin-top: 50px;
        }
        #console { margin-top: 20px; font-size: 12px; text-align: left; padding: 10px; }
    </style>
</head>
<body>

    <h2>DIABLO VPN v5.0</h2>
    <button class="btn" onclick="iniciarConexion()">CONECTAR</button>
    <div id="console">> Esperando inicio...</div>

    <script>
        // ESTA ES LA PARTE QUE TE PERDÍA: El código que habla con Java
        function iniciarConexion() {
            const log = document.getElementById('console');
            log.innerHTML += "<br>> Iniciando motor nativo...";

            // 1. Aquí le gritamos al "puente" que creamos en MainActivity.java
            if (window.AndroidVPN) {
                log.innerHTML += "<br>> Solicitando permiso de túnel...";
                window.AndroidVPN.prepararVPN(); // Esto activa la LLAVE
            } else {
                // Esto solo sale si pruebas el código en un navegador y no en el APK
                log.innerHTML += "<br>> Error: No se detectó el motor nativo.";
            }
        }
    </script>

</body>
</html>
