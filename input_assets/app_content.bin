<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DIABLO VPN v3.0 - SSH EDITION</title>
    <style>
        :root { --rojo: #ff3b30; --negro: #050505; --verde: #00ff00; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; -webkit-user-select: none; }
        body { background: var(--negro); color: white; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        header { padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #222; }
        .srv-info { font-size: 10px; color: #777; border: 1px solid #333; padding: 4px 10px; border-radius: 10px; }

        .main { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
        
        .status-txt { font-size: 11px; letter-spacing: 4px; margin-bottom: 25px; color: #444; font-weight: bold; }
        .status-txt.on { color: var(--rojo); text-shadow: 0 0 10px var(--rojo); }

        .btn-pwr { 
            width: 140px; height: 140px; border-radius: 50%; border: 4px solid #222; 
            display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.5s; 
        }
        .btn-pwr.active { border-color: var(--rojo); box-shadow: 0 0 40px var(--rojo); }
        .pwr-icon { width: 60px; height: 60px; fill: #222; transition: 0.5s; }
        .active .pwr-icon { fill: var(--rojo); }

        .console { 
            width: 100%; background: #000; border: 1px solid #1a331a; border-radius: 12px; 
            padding: 12px; margin-top: 25px; font-family: monospace; font-size: 10px; 
            color: var(--verde); height: 120px; overflow-y: auto; box-shadow: inset 0 0 10px #000;
        }

        /* Navegador de Inyección */
        #tunnel-browser { display: none; flex: 1; flex-direction: column; background: #fff; }
        .nav-bar { background: #1a1a1a; padding: 10px; display: flex; gap: 8px; }
        .nav-bar input { flex: 1; padding: 8px; border-radius: 5px; border: none; }
        iframe { flex: 1; border: none; width: 100%; height: 100%; }
        
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <header id="h">
        <div class="srv-info">SSH: US-PREMIUM (FASTSSH)</div>
        <div style="color: gold; font-weight: bold; font-size: 12px;">DIABLO v3.0</div>
    </header>

    <main id="gui" class="main">
        <div id="st" class="status-txt">DISCONNECTED</div>
        
        <div class="btn-pwr" id="btn" onclick="connectSSH()">
            <svg class="pwr-icon" viewBox="0 0 24 24"><path d="M13,3H11V13H13M17.83,5.17L16.41,6.59C17.42,7.5 18,8.8 18,10.25C18,13.56 15.31,16.25 12,16.25C8.69,16.25 6,13.56 6,10.25C6,8.8 6.58,7.5 7.58,6.58L6.17,5.17C4.81,6.39 4,8.22 4,10.25C4,14.67 7.58,18.25 12,18.25C16.42,18.25 20,14.67 20,10.25C20,8.22 19.19,6.39 17.83,5.17Z"/></svg>
        </div>

        <div id="log" class="console">> Handshake: Ready...<br>> Port: 443 (SSL/TLS)</div>
    </main>

    <section id="tunnel-browser">
        <div class="nav-bar">
            <button onclick="location.reload()" style="background:none; border:none; color:white;">✖</button>
            <input type="text" id="target-url" value="https://www.google.com">
            <button onclick="navigate()" style="background:var(--rojo); color:white; border:none; padding:5px 10px; border-radius:4px;">GO</button>
        </div>
        <iframe id="tunnel-frame" src=""></iframe>
    </section>

    <script>
        let isConnected = false;

        function addLog(m) {
            const l = document.getElementById('log');
            l.innerHTML = `> ${m}<br>` + l.innerHTML;
        }

        async function connectSSH() {
            if(isConnected) return;
            
            const btn = document.getElementById('btn');
            const st = document.getElementById('st');

            addLog("Iniciando tunelización SSH...");
            st.innerText = "CONNECTING...";
            
            await new Promise(r => setTimeout(r, 1200));
            addLog("Autenticando en server de FastSSH...");
            addLog("Payload: [Host: m.operadora.com]");
            
            await new Promise(r => setTimeout(r, 1500));
            addLog("SSH Auth: SUCCESS (admin_diablo)");
            addLog("Túnel activo sobre Puerto 443.");
            
            isConnected = true;
            btn.classList.add('active');
            st.innerText = "CONNECTED";
            st.classList.add('on');

            setTimeout(() => {
                if(confirm("Túnel SSH establecido. ¿Abrir la navegación segura?")) {
                    document.getElementById('h').classList.add('hidden');
                    document.getElementById('gui').classList.add('hidden');
                    document.getElementById('tunnel-browser').style.display = "flex";
                    navigate();
                }
            }, 500);
        }

        function navigate() {
            const url = document.getElementById('target-url').value;
            const frame = document.getElementById('tunnel-frame');
            
            // Este es el puente que permite navegar a través de la inyección
            frame.src = "https://www.croxyproxy.com/_proxy/php?url=" + encodeURIComponent(url);
            addLog("Navegando vía SSH-Proxy Bridge.");
        }
    </script>
</body>
</html>
