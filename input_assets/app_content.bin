<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>WebForge Pro — Constructor de APK</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f0f2f7; --white: #ffffff; --blue: #3b82f6; --blue-d: #2563eb;
            --text: #1a1a2e; --muted: #6b7280; --border: #e5e7eb; --green: #10b981;
            --shadow: 0 4px 12px rgba(0,0,0,0.08); --r: 14px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { background: var(--bg); color: var(--text); overflow-x: hidden; }

        /* Vistas */
        .view { display: none; min-height: 100vh; flex-direction: column; }
        .view.active { display: flex; }

        /* Navbar */
        .navbar { background: var(--white); padding: 0 18px; height: 60px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
        .logo { font-weight: 800; font-size: 18px; }
        .logo span { color: var(--blue); }
        .nav-btn { width: 40px; height: 40px; border-radius: 10px; border: 1px solid var(--border); background: none; cursor: pointer; display: flex; align-items: center; justify-content: center; }

        /* Dashboard */
        .dash-content { padding: 20px; flex: 1; }
        .app-card { background: var(--white); padding: 16px; border-radius: var(--r); display: flex; align-items: center; gap: 15px; margin-bottom: 12px; box-shadow: var(--shadow); border: 1px solid var(--border); }
        .app-card-icon { width: 50px; height: 50px; background: var(--bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; overflow: hidden; }
        .app-card-icon img { width: 100%; height: 100%; object-fit: cover; }
        .fab { position: fixed; bottom: 25px; right: 20px; width: 60px; height: 60px; border-radius: 20px; background: var(--blue); color: white; font-size: 30px; border: none; box-shadow: 0 5px 15px rgba(59, 130, 246, 0.4); cursor: pointer; }

        /* Wizard */
        .wiz-container { padding: 20px; flex: 1; }
        .step-card { background: var(--white); padding: 25px; border-radius: 20px; text-align: center; border: 1px solid var(--border); margin-bottom: 20px; }
        .step-card h2 { color: var(--blue); margin-bottom: 10px; font-weight: 800; }
        .field { text-align: left; margin-bottom: 15px; }
        .field label { display: block; font-size: 12px; font-weight: 700; color: var(--muted); margin-bottom: 5px; text-transform: uppercase; }
        .inp { width: 100%; padding: 14px; border-radius: 12px; border: 1.5px solid var(--border); outline: none; font-size: 15px; }
        .inp:focus { border-color: var(--blue); }

        /* Botones */
        .btn-group { padding: 15px 20px; background: var(--white); border-top: 1px solid var(--border); display: flex; gap: 10px; }
        .btn { flex: 1; padding: 16px; border-radius: 12px; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; }
        .btn-blue { background: var(--blue); color: white; }
        .btn-ghost { background: var(--bg); color: var(--text); }

        /* Source Toggle */
        .toggle-group { display: flex; background: var(--bg); padding: 4px; border-radius: 12px; margin-bottom: 15px; }
        .toggle-btn { flex: 1; padding: 10px; border-radius: 10px; border: none; cursor: pointer; font-weight: 600; background: none; color: var(--muted); }
        .toggle-btn.active { background: var(--white); color: var(--blue); box-shadow: var(--shadow); }

        /* Loader */
        .proc-view { align-items: center; justify-content: center; padding: 40px; text-align: center; }
        .loader { width: 50px; height: 50px; border: 5px solid #eee; border-top: 5px solid var(--blue); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
        .proc-step { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: 14px; color: var(--muted); }
        .proc-step.active { color: var(--blue); font-weight: 700; }
        .proc-step.done { color: var(--green); }

        #toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%); background: #1e1e2e; color: white; padding: 12px 25px; border-radius: 50px; font-size: 14px; opacity: 0; transition: 0.3s; z-index: 1000; }
        #toast.show { opacity: 1; }
    </style>
</head>
<body>

<div id="toast">Notificación</div>

<!-- VISTA DASHBOARD -->
<div class="view active" id="v-dashboard">
    <nav class="navbar">
        <div class="logo">WebForge<span>Pro</span></div>
        <button class="nav-btn" onclick="goto('v-settings')">⚙️</button>
    </nav>
    <div class="dash-content">
        <h1 style="font-size: 24px; margin-bottom: 5px;">Mis Proyectos</h1>
        <p style="color: var(--muted); font-size: 14px; margin-bottom: 20px;">Gestiona tus aplicaciones APK</p>
        <div id="apps-list">
            <!-- Aquí se cargan las apps -->
            <div style="text-align: center; padding: 50px; color: var(--muted);">No hay apps aún. Toca el botón +</div>
        </div>
    </div>
    <button class="fab" onclick="openWizard()">+</button>
</div>

<!-- VISTA WIZARD -->
<div class="view" id="v-wizard">
    <nav class="navbar">
        <button class="nav-btn" onclick="goto('v-dashboard')">✕</button>
        <div class="logo">Constructor</div>
        <div style="width: 40px;"></div>
    </nav>
    <div class="wiz-container">
        <!-- Paso 1 -->
        <div id="wiz-step-1" class="wiz-step-content">
            <div class="step-card">
                <h2>¿Qué convertiremos?</h2>
                <p>Elige si usarás una web online o archivos locales.</p>
            </div>
            <div class="toggle-group">
                <button class="toggle-btn active" id="btn-type-url" onclick="setSourceType('url')">URL Web</button>
                <button class="toggle-btn" id="btn-type-file" onclick="setSourceType('file')">HTML / ZIP</button>
            </div>
            <div id="input-url-container">
                <div class="field">
                    <label>URL del sitio</label>
                    <input type="url" class="inp" id="app-url" placeholder="https://mi-web.com">
                </div>
            </div>
            <div id="input-file-container" style="display: none;">
                <div class="field">
                    <label>Archivo local</label>
                    <button class="btn btn-ghost" onclick="document.getElementById('file-input').click()" id="file-label">📁 Seleccionar HTML o ZIP</button>
                    <input type="file" id="file-input" hidden onchange="handleFile(this)" accept=".html,.zip">
                </div>
            </div>
        </div>

        <!-- Paso 2 -->
        <div id="wiz-step-2" class="wiz-step-content" style="display: none;">
            <div class="step-card">
                <h2>Identidad de la App</h2>
                <p>Define cómo se verá en el teléfono.</p>
            </div>
            <div class="field">
                <label>Nombre de la Aplicación</label>
                <input type="text" class="inp" id="app-name" placeholder="Ej: Mi Tienda Online">
            </div>
            <div class="field">
                <label>Package ID</label>
                <input type="text" class="inp" id="app-pkg" value="com.webforge.app">
            </div>
            <div class="field">
                <label>Icono de la App</label>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <div id="icon-preview" style="width: 60px; height: 60px; background: #eee; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; overflow: hidden;">📱</div>
                    <button class="btn btn-ghost" onclick="document.getElementById('icon-input').click()">Subir Imagen</button>
                    <input type="file" id="icon-input" hidden onchange="handleIcon(this)" accept="image/*">
                </div>
            </div>
        </div>
    </div>
    <div class="btn-group">
        <button class="btn btn-ghost" id="btn-back" style="display: none;" onclick="wizBack()">Atrás</button>
        <button class="btn btn-blue" id="btn-next" onclick="wizNext()">Continuar</button>
    </div>
</div>

<!-- VISTA PROCESAMIENTO -->
<div class="view proc-view" id="v-processing">
    <div class="loader"></div>
    <h2 id="proc-title">Iniciando proceso...</h2>
    <p style="color: var(--muted); font-size: 14px; margin-bottom: 30px;" id="proc-status">Estamos conectando con GitHub Actions</p>
    <div style="width: 100%; max-width: 250px; margin: 0 auto;">
        <div class="proc-step" id="step-0">⚪ Subiendo archivos web</div>
        <div class="proc-step" id="step-1">⚪ Procesando icono</div>
        <div class="proc-step" id="step-2">⚪ Generando config.json</div>
        <div class="proc-step" id="step-3">⚪ Disparando compilador</div>
    </div>
</div>

<!-- VISTA SETTINGS -->
<div class="view" id="v-settings">
    <nav class="navbar">
        <button class="nav-btn" onclick="goto('v-dashboard')">←</button>
        <div class="logo">Configuración</div>
        <div style="width: 40px;"></div>
    </nav>
    <div style="padding: 20px;">
        <div class="field">
            <label>GitHub Personal Token</label>
            <input type="password" class="inp" id="cfg-token" placeholder="ghp_xxxxxxxxxxxx">
        </div>
        <div class="field">
            <label>Usuario GitHub</label>
            <input type="text" class="inp" id="cfg-user" value="javierc232">
        </div>
        <div class="field">
            <label>Repositorio</label>
            <input type="text" class="inp" id="cfg-repo" value="Generador-apk">
        </div>
        <button class="btn btn-blue" style="width: 100%;" onclick="saveSettings()">Guardar Cambios</button>
    </div>
</div>

<script>
    // ESTADO GLOBAL
    let currentStep = 1;
    let wizData = {
        sourceType: 'url',
        fileBase64: null,
        fileName: '',
        iconBase64: null,
        iconUrl: null
    };

    // NAVEGACIÓN
    function goto(id) {
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    function openWizard() {
        currentStep = 1;
        updateWizardUI();
        goto('v-wizard');
    }

    function setSourceType(type) {
        wizData.sourceType = type;
        document.getElementById('btn-type-url').classList.toggle('active', type === 'url');
        document.getElementById('btn-type-file').classList.toggle('active', type === 'file');
        document.getElementById('input-url-container').style.display = (type === 'url' ? 'block' : 'none');
        document.getElementById('input-file-container').style.display = (type === 'file' ? 'block' : 'none');
    }

    function updateWizardUI() {
        document.getElementById('wiz-step-1').style.display = (currentStep === 1 ? 'block' : 'none');
        document.getElementById('wiz-step-2').style.display = (currentStep === 2 ? 'block' : 'none');
        document.getElementById('btn-back').style.display = (currentStep === 1 ? 'none' : 'block');
        document.getElementById('btn-next').innerText = (currentStep === 2 ? 'Generar APK Real' : 'Continuar');
    }

    function wizNext() {
        if (currentStep === 1) {
            currentStep = 2;
            updateWizardUI();
        } else {
            startBuild();
        }
    }

    function wizBack() {
        currentStep = 1;
        updateWizardUI();
    }

    // MANEJO DE ARCHIVOS
    function handleFile(input) {
        const file = input.files[0];
        if (!file) return;
        wizData.fileName = file.name;
        document.getElementById('file-label').innerText = "✅ " + file.name;
        const reader = new FileReader();
        reader.onload = (e) => { wizData.fileBase64 = e.target.result.split(',')[1]; };
        reader.readAsDataURL(file);
    }

    function handleIcon(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (e) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                canvas.width = 96; canvas.height = 96;
                canvas.getContext('2d').drawImage(img, 0, 0, 96, 96);
                wizData.iconBase64 = canvas.toDataURL('image/png').split(',')[1];
                wizData.iconUrl = canvas.toDataURL('image/png');
                document.getElementById('icon-preview').innerHTML = `<img src="${wizData.iconUrl}">`;
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    // GITHUB LOGIC
    async function uploadToGithub(token, user, repo, path, content) {
        const url = `https://api.github.com/repos/${user}/${repo}/contents/${path}`;
        let sha = null;
        try {
            const check = await fetch(url, { headers: { "Authorization": `Bearer ${token}` } });
            if (check.ok) { const data = await check.json(); sha = data.sha; }
        } catch (e) {}

        const res = await fetch(url, {
            method: "PUT",
            headers: { "Authorization": `Bearer ${token}`, "Content-Type": "application/json" },
            body: JSON.stringify({ message: "Upload from WebForge", content: content, sha: sha })
        });
        return res.ok;
    }

    async function startBuild() {
        const settings = getSettings();
        const appName = document.getElementById('app-name').value;
        if (!settings.token || !appName) {
            showToast("⚠️ Falta el token o nombre de app");
            return;
        }

        goto('v-processing');

        try {
            // Paso 0: Web
            updateProc(0, 'active');
            if (wizData.sourceType === 'file' && wizData.fileBase64) {
                await uploadToGithub(settings.token, settings.user, settings.repo, "input_assets/app_content.bin", wizData.fileBase64);
            }
            updateProc(0, 'done');

            // Paso 1: Icono
            updateProc(1, 'active');
            if (wizData.iconBase64) {
                await uploadToGithub(settings.token, settings.user, settings.repo, "input_assets/icon.png", wizData.iconBase64);
            }
            updateProc(1, 'done');

            // Paso 2: Config
            updateProc(2, 'active');
            const config = {
                app_name: appName,
                package_id: document.getElementById('app-pkg').value,
                source_type: wizData.sourceType,
                content: wizData.sourceType === 'url' ? document.getElementById('app-url').value : null,
                file_ext: wizData.fileName.split('.').pop() || 'html'
            };
            await uploadToGithub(settings.token, settings.user, settings.repo, "input_assets/config.json", btoa(JSON.stringify(config)));
            updateProc(2, 'done');

            // Paso 3: Dispatch
            updateProc(3, 'active');
            const dispatch = await fetch(`https://api.github.com/repos/${settings.user}/${settings.repo}/dispatches`, {
                method: "POST",
                headers: { "Authorization": `Bearer ${settings.token}`, "Accept": "application/vnd.github.v3+json" },
                body: JSON.stringify({ event_type: "build_app", client_payload: config })
            });

            if (dispatch.ok) {
                updateProc(3, 'done');
                document.getElementById('proc-title').innerText = "¡Enviado con éxito!";
                document.getElementById('proc-status').innerText = "Tu APK estará lista en unos minutos en GitHub Releases.";
                saveAppLocally(config, wizData.iconUrl);
                setTimeout(() => { location.reload(); }, 3000);
            } else {
                showToast("❌ Error al disparar GitHub");
                goto('v-dashboard');
            }

        } catch (e) {
            showToast("❌ Error crítico: " + e.message);
            goto('v-dashboard');
        }
    }

    // UTILIDADES
    function saveSettings() {
        const s = {
            token: document.getElementById('cfg-token').value,
            user: document.getElementById('cfg-user').value,
            repo: document.getElementById('cfg-repo').value
        };
        localStorage.setItem('wf_settings', JSON.stringify(s));
        showToast("✅ Ajustes guardados");
        goto('v-dashboard');
    }

    function getSettings() {
        return JSON.parse(localStorage.getItem('wf_settings')) || { user: 'javierc232', repo: 'Generador-apk' };
    }

    function showToast(msg) {
        const t = document.getElementById('toast');
        t.innerText = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    function updateProc(id, state) {
        const el = document.getElementById('step-' + id);
        if (state === 'active') { el.innerText = "🔵 " + el.innerText.substring(2); el.classList.add('active'); }
        if (state === 'done') { el.innerText = "✅ " + el.innerText.substring(2); el.classList.add('done'); }
    }

    function saveAppLocally(config, icon) {
        let apps = JSON.parse(localStorage.getItem('wf_apps_list')) || [];
        apps.push({ name: config.app_name, pkg: config.package_id, icon: icon });
        localStorage.setItem('wf_apps_list', JSON.stringify(apps));
    }

    function renderApps() {
        const list = document.getElementById('apps-list');
        let apps = JSON.parse(localStorage.getItem('wf_apps_list')) || [];
        if (apps.length > 0) {
            list.innerHTML = apps.map(app => `
                <div class="app-card">
                    <div class="app-card-icon">${app.icon ? `<img src="${app.icon}">` : '📱'}</div>
                    <div style="flex:1">
                        <div style="font-weight:700">${app.name}</div>
                        <div style="font-size:12px; color:var(--muted)">${app.pkg}</div>
                    </div>
                    <div style="font-size:10px; font-weight:800; color:var(--blue)">CONSTRUIDO</div>
                </div>
            `).join('');
        }
    }

    // INIT
    window.onload = () => {
        const s = getSettings();
        if (s.token) document.getElementById('cfg-token').value = s.token;
        document.getElementById('cfg-user').value = s.user;
        document.getElementById('cfg-repo').value = s.repo;
        renderApps();
    };

</script>
</body>
</html>