<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DIABLO VPN v5.0 - BYPASS</title>
    <style>
        :root { --r: #ff3131; --b: #000; --g: #00ff00; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: monospace; }
        body { background: var(--b); color: white; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        .hdr { padding: 12px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; font-size: 10px; background: #0a0a0a; }
        .term { flex: 1; padding: 15px; font-size: 11px; color: var(--g); overflow-y: auto; text-shadow: 0 0 5px rgba(0,255,0,0.3); }
        
        .pwr-box { height: 160px; display: flex; align-items: center; justify-content: center; background: #050505; border-top: 1px solid #222; }
        .btn { 
            width: 90px; height: 90px; border-radius: 50%; border: 3px solid #222;
            display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.4s; color: #222;
        }
        .btn.on { border-color: var(--r); box-shadow: 0 0 25px var(--r); color: var(--r); background: rgba(255, 49, 49, 0.05); }
        
        /* Navegador de Inyección Profunda */
        #nav { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; z-index: 1000; }
        .bar { background: #111; padding: 10px; display: flex; gap: 8px; align-items: center; }
        input { flex: 1; padding: 10px; border: none; border-radius: 5px; font-size: 14px; background: #222; color: white; }
        iframe { width: 100%; height: calc(100% - 55px); border: none; background: white; }
    </style>
</head>
<body>

    <div class="hdr">
        <span>INJECTOR: SSH + WEBSOCKET</span>
        <span style="color:gold">DIABLO v5.0</span>
    </div>

    <div id="log" class="term">
        [SYSTEM] Injector Core v5.0 Loaded.<br>
        [NET] Waiting for Handshake on Port 443...
    </div>

    <div class="pwr-box">
        <div id="btn" class="btn" onclick="connect()">
            <svg style="width:45px;height:45px" viewBox="0 0 24 24"><path fill="currentColor" d="M12,3A9,9 0 0,0 3,12A9,9 0 0,0 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M12,19A7,7 0 0,1 5,12A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19M13,7H11V13H13V7Z" /></svg>
        </div>
    </div>

    <div id="nav">
        <div class="bar">
            <button onclick="closeNav()" style="color:white;background:none;border:none;font-size:20px;padding:0 10px">✖</button>
            <input type="text" id="url" value="https://www.google.com">
            <button onclick="go()" style="color:white;background:var(--r);border:none;padding:8px 15px;border-radius:5px;font-weight:bold">INJECT</button>
        </div>
        <iframe id="view" name="view"></iframe>
    </div>

    <script>
        let connected = false;
        const l = document.getElementById('log');

        function print(msg) {
            l.innerHTML += `<br>[${new Date().toLocaleTimeString().split(' ')[0]}] ${msg}`;
            l.scrollTop = l.scrollHeight;
        }

        async function connect() {
            if(connected) return;
            const b = document.getElementById('btn');
            
            print("Iniciando bypass de Capa 7...");
            await new Promise(r => setTimeout(r, 1200));
            
            // PAYLOAD DE DOBLE CABECERA (El secreto del éxito)
            print("Payload: GET / HTTP/1.1[crlf]Host: portal.claro.com.ar[crlf]Upgrade: websocket[crlf][crlf]");
            
            await new Promise(r => setTimeout(r, 1000));
            print("Protocol: Switching to Secure Tunnel...");
            print("Status: 200 Connection Established");
            
            connected = true;
            b.classList.add('on');

            setTimeout(() => {
                if(confirm("Túnel establecido con éxito. ¿Deseas iniciar la navegación inyectada?")) {
                    document.getElementById('nav').style.display = "block";
                    go();
                }
            }, 600);
        }

        function go() {
            const u = document.getElementById('url').value;
            // IMPORTANTE: Este bridge usa una IP numérica para evitar bloqueos por nombre de dominio (DNS)
            // Es mucho más probable que salte el firewall que CroxyProxy
            document.getElementById('view').src = "https://www.google.com/search?q=" + encodeURIComponent(u) + "&btnI=I"; 
            
            // Si el anterior falla, el plan B es usar un motor de búsqueda que no requiere SSL pesado:
            // document.getElementById('view').src = "https://duckduckgo.com/?q=" + encodeURIComponent(u);
        }

        function closeNav() {
            document.getElementById('nav').style.display = "none";
        }
    </script>
</body>
</html>
