            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f)); row.addView(lbl);
        android.widget.Switch sw = new android.widget.Switch(this);
        sw.setChecked(bottomNav);
        sw.setOnCheckedChangeListener((b, c) -> bottomNav = c);
        row.addView(sw); stepContent.addView(row);
