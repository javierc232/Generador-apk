    // Paso 7: User agent
    private void buildStep7() {
        stepContent.addView(secLabel("🌐  User Agent (Opcional)"));
        String[] presets = {
            "Mozilla/5.0 (Android) Chrome/120",
            "Mozilla/5.0 (iPhone) Safari/604",
            "Mozilla/5.0 (Windows) Chrome/120",
            "Mozilla/5.0 (Macintosh) Safari/537"
        };
        TextView presetBtn = new TextView(this);
        presetBtn.setText("≡  Seleccionar de presets");
        presetBtn.setTextSize(14); presetBtn.setTextColor(Color.parseColor("#4F6EF7"));
        presetBtn.setGravity(Gravity.CENTER); presetBtn.setPadding(dp(16), dp(14), dp(16), dp(14));
        GradientDrawable pb = new GradientDrawable();
        pb.setColor(Color.parseColor("#161B22")); pb.setCornerRadius(dp(40));
        pb.setStroke(dp(1), Color.parseColor("#4F6EF7")); presetBtn.setBackground(pb);

        EditText etUA = styledField("Custom User Agent (vacío = predeterminado)");
        if (!userAgent.isEmpty()) etUA.setText(userAgent);
        etUA.addTextChangedListener(tw(s -> userAgent = s));
        presetBtn.setOnClickListener(v ->
