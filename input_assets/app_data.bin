        iconRow.setPadding(0, 0, 0, dp(20)); iconRow.setOnClickListener(v -> pickIcon());

        ivIcon = new ImageView(this);
        int sz = dp(70);
        LinearLayout.LayoutParams iLp = new LinearLayout.LayoutParams(sz, sz);
        iLp.setMargins(0, 0, dp(16), 0); ivIcon.setLayoutParams(iLp);
        ivIcon.setScaleType(ImageView.ScaleType.CENTER_CROP);
        GradientDrawable iBg = new GradientDrawable();
        iBg.setColor(Color.parseColor("#161B22")); iBg.setCornerRadius(dp(16));
        iBg.setStroke(dp(2), Color.parseColor("#21262D")); ivIcon.setBackground(iBg);
        iconRow.addView(ivIcon);

        LinearLayout iconTxt = new LinearLayout(this);
        iconTxt.setOrientation(LinearLayout.VERTICAL);
        iconTxt.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
        TextView iconT = new TextView(this);
        iconT.setText("Sin ícono — toca para elegir"); iconT.setTextSize(14); iconT.setTextColor(Color.WHITE);
        iconTxt.addView(iconT);
        TextView iconS = new TextView(this);
        iconS.setText("PNG o JPG recomendado"); iconS.setTextSize(12); iconS.setTextColor(Color.parseColor("#4F6EF7"));
