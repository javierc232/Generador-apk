    private void loadProjects() {
        projectsContainer.removeAllViews();
        try {
            JSONArray arr = new JSONArray(
                getSharedPreferences(PREFS, MODE_PRIVATE).getString(KEY_PROJ, "[]"));
            if (arr.length() == 0) { emptyState(); return; }
            for (int i = 0; i < arr.length(); i++) addCard(arr.getJSONObject(i));
        } catch (Exception e) { emptyState(); }
    }

    private void emptyState() {
        LinearLayout box = new LinearLayout(this);
        box.setOrientation(LinearLayout.VERTICAL);
        box.setGravity(Gravity.CENTER);
        box.setPadding(dp(32), dp(64), dp(32), dp(64));
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(20));
        bg.setStroke(dp(1), Color.parseColor("#21262D")); box.setBackground(bg);

        TextView ic = new TextView(this); ic.setText("📦"); ic.setTextSize(52);
        ic.setGravity(Gravity.CENTER); box.addView(ic);

        TextView t = new TextView(this); t.setText("Sin proyectos aún");
        t.setTextSize(18); t.setTypeface(Typeface.DEFAULT_BOLD);
        t.setTextColor(Color.WHITE); t.setGravity(Gravity.CENTER);
        t.setPadding(0, dp(12), 0, dp(6)); box.addView(t);

        TextView d = new TextView(this);
        d.setText("Toca «Nuevo Proyecto» para subir\ntus archivos y generar tu APK");
        d.setTextSize(13); d.setTextColor(Color.parseColor("#64748B"));
        d.setGravity(Gravity.CENTER); box.addView(d);
        projectsContainer.addView(box);
    }

    private void addCard(JSONObject p) {
        try {
            String id     = p.optString("id");
            String name   = p.optString("name", "Proyecto");
            String status = p.optString("status", "Pendiente");
            String color  = p.optString("color", "#4F6EF7");
            int    fCount = p.optInt("fileCount", 0);
            boolean done  = "Completado".equals(status);

            FrameLayout card = new FrameLayout(this);
            GradientDrawable cardBg = new GradientDrawable();
            cardBg.setColor(Color.parseColor("#161B22")); cardBg.setCornerRadius(dp(18));
            cardBg.setStroke(dp(1), done
                ? Color.parseColor("#1A3A2A") : Color.parseColor("#21262D"));
            card.setBackground(cardBg); card.setElevation(dp(6));
            LinearLayout.LayoutParams cLp = new LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
            cLp.setMargins(0, 0, 0, dp(12)); card.setLayoutParams(cLp);

            View bar = new View(this);
            GradientDrawable barBg = new GradientDrawable(
                GradientDrawable.Orientation.LEFT_RIGHT,
                new int[]{Color.parseColor(color), Color.parseColor(color + "33")});
            barBg.setCornerRadii(new float[]{dp(18),dp(18),dp(18),dp(18),0,0,0,0});
            bar.setBackground(barBg);
            bar.setLayoutParams(new FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, dp(4)));
            card.addView(bar);

            LinearLayout inner = new LinearLayout(this);
            inner.setOrientation(LinearLayout.VERTICAL);
            inner.setPadding(dp(16), dp(16), dp(16), dp(14));
            FrameLayout.LayoutParams iLp = new FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT);
            iLp.topMargin = dp(4); inner.setLayoutParams(iLp);

            LinearLayout r1 = new LinearLayout(this);
            r1.setOrientation(LinearLayout.HORIZONTAL); r1.setGravity(Gravity.CENTER_VERTICAL);
            TextView tvN = new TextView(this); tvN.setText(name); tvN.setTextSize(17);
            tvN.setTypeface(Typeface.DEFAULT_BOLD); tvN.setTextColor(Color.WHITE);
            tvN.setLayoutParams(new LinearLayout.LayoutParams(
                0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f)); r1.addView(tvN);
            TextView tvM = new TextView(this); tvM.setText("⋮"); tvM.setTextSize(20);
            tvM.setTextColor(Color.parseColor("#64748B")); tvM.setPadding(dp(12), 0, 0, 0);
            tvM.setOnClickListener(v -> cardMenu(id, name)); r1.addView(tvM);
            inner.addView(r1);

            LinearLayout r2 = new LinearLayout(this);
            r2.setOrientation(LinearLayout.HORIZONTAL); r2.setGravity(Gravity.CENTER_VERTICAL);
            r2.setPadding(0, dp(8), 0, 0);
            TextView tvF = new TextView(this);
            tvF.setText("📎 " + fCount + " archivo" + (fCount == 1 ? "" : "s"));
            tvF.setTextSize(12); tvF.setTextColor(Color.parseColor("#64748B"));
            tvF.setLayoutParams(new LinearLayout.LayoutParams(
                0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f)); r2.addView(tvF);
            TextView badge = new TextView(this);
            badge.setText(done ? "✓ Listo" : "⏳ " + status);
            badge.setTextSize(11); badge.setTypeface(Typeface.DEFAULT_BOLD);
            badge.setTextColor(done
                ? Color.parseColor("#22C55E") : Color.parseColor("#F59E0B"));
            badge.setPadding(dp(10), dp(4), dp(10), dp(4));
            GradientDrawable bdg = new GradientDrawable();
            bdg.setColor(done ? Color.parseColor("#0F2A1A") : Color.parseColor("#2A1F0A"));
            bdg.setCornerRadius(dp(20)); badge.setBackground(bdg); r2.addView(badge);
            inner.addView(r2);
            card.addView(inner);
            projectsContainer.addView(card);
        } catch (Exception ignored) {}
    }

    private void cardMenu(String id, String name) {
        new AlertDialog.Builder(this).setTitle(name)
            .setItems(new String[]{
                "📥 Descargar APK",
                "🔗 Ver GitHub Actions",
                "✏️ Editar proyecto",
                "🗑 Eliminar"
            }, (d, w) -> {
                switch (w) {
                    case 0: case 1:
                        startActivity(new Intent(Intent.ACTION_VIEW,
                            Uri.parse("https://github.com/javierc232/Generador-apk/actions")));
                        break;
                    case 2:
                        Intent i = new Intent(this, WizardActivity.class);
                        i.putExtra("project_id", id); startActivity(i); break;
                    case 3: confirmDelete(id); break;
                }
            }).show();
    }

    private void confirmDelete(String id) {
        new AlertDialog.Builder(this).setTitle("¿Eliminar?")
            .setMessage("Esta acción no se puede deshacer.")
            .setPositiveButton("Eliminar", (d, w) -> {
                try {
                    SharedPreferences sp = getSharedPreferences(PREFS, MODE_PRIVATE);
                    JSONArray a = new JSONArray(sp.getString(KEY_PROJ, "[]"));
                    JSONArray n = new JSONArray();
                    for (int i = 0; i < a.length(); i++)
                        if (!a.getJSONObject(i).optString("id").equals(id)) n.put(a.getJSONObject(i));
                    sp.edit().putString(KEY_PROJ, n.toString()).apply(); loadProjects();
                } catch (Exception ignored) {}
            }).setNegativeButton("Cancelar", null).show();
    }

    private int dp(int v) {
        return (int) TypedValue.applyDimension(
            TypedValue.COMPLEX_UNIT_DIP, v, getResources().getDisplayMetrics());
    }
}

// ═════════════════════════════════════════════════════════════════════════════
//  WIZARD ACTIVITY — 9 pasos, permisos solo cuando se necesitan
// ═════════════════════════════════════════════════════════════════════════════
class WizardActivity extends AppCompatActivity {

    private static final int TOTAL    = 9;
    private static final int REQ_FILES = 4001;
    private static final int REQ_ZIP   = 4002;
    private static final int REQ_ICON  = 4003;
    private static final int REQ_STORAGE = 4004;
    private static final String PREFS    = "wf_prefs";
    private static final String KEY_PROJ = "saved_projects";

    // Datos del proyecto
    private String  projectId    = UUID.randomUUID().toString();
    private String  appName      = "";
    private String  packageName  = "";
    private String  version      = "1";
    private String  themeColor   = "#4F6EF7";
    private String  progressStyle = "Circular";
    private String  userAgent    = "";
    private boolean bottomNav    = false;
    private String  purpose      = "Personal Use";
    private String  iconPath     = "";
    private final List<ProjectFile> files    = new ArrayList<>();
    private final List<String>      features = new ArrayList<>();

    // Acción pendiente después de obtener permiso
    private Runnable pendingAction = null;

    private int step = 1;
    private FrameLayout root;
    private LinearLayout dotsRow, stepContent, bottomBar;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        String extId = getIntent().getStringExtra("project_id");
        if (extId != null && !extId.isEmpty()) projectId = extId;
        buildShell();
        renderStep();
    }

    // ── Shell ─────────────────────────────────────────────────────────────────
    private void buildShell() {
        root = new FrameLayout(this);
        root.setBackgroundColor(Color.parseColor("#0D1117"));

        LinearLayout shell = new LinearLayout(this);
        shell.setOrientation(LinearLayout.VERTICAL);
        shell.setPadding(0, dp(40), 0, 0);

        dotsRow = new LinearLayout(this);
        dotsRow.setOrientation(LinearLayout.HORIZONTAL);
        dotsRow.setGravity(Gravity.CENTER);
        dotsRow.setPadding(0, dp(8), 0, dp(16));
        shell.addView(dotsRow);

        FrameLayout headerSlot = new FrameLayout(this);
        headerSlot.setId(0x1001);
        LinearLayout.LayoutParams hLp = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        hLp.setMargins(dp(16), 0, dp(16), dp(12));
        headerSlot.setLayoutParams(hLp);
        shell.addView(headerSlot);

        ScrollView sv = new ScrollView(this); sv.setFillViewport(true);
        stepContent = new LinearLayout(this);
        stepContent.setOrientation(LinearLayout.VERTICAL);
        stepContent.setPadding(dp(16), 0, dp(16), dp(16));
        sv.addView(stepContent);
        LinearLayout.LayoutParams svLp = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 0, 1f);
        sv.setLayoutParams(svLp);
        shell.addView(sv);

        bottomBar = new LinearLayout(this);
        bottomBar.setOrientation(LinearLayout.VERTICAL);
        bottomBar.setPadding(dp(16), dp(12), dp(16), dp(28));
        shell.addView(bottomBar);

        root.addView(shell);
        setContentView(root);
    }

    private void renderStep() {
        // Dots
        dotsRow.removeAllViews();
        for (int i = 1; i <= TOTAL; i++) {
            View dot = new View(this);
            int size = (i == step) ? dp(12) : dp(8);
            LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(size, size);
            lp.setMargins(dp(4), 0, dp(4), 0); dot.setLayoutParams(lp);
            GradientDrawable db = new GradientDrawable(); db.setShape(GradientDrawable.OVAL);
            db.setColor(i <= step ? Color.parseColor("#4F6EF7") : Color.parseColor("#21262D"));
            dot.setBackground(db); dotsRow.addView(dot);
        }

        // Header
        FrameLayout headerSlot = root.findViewById(0x1001);
        if (headerSlot != null) { headerSlot.removeAllViews(); headerSlot.addView(buildHeader()); }

        // Contenido
        stepContent.removeAllViews();
        buildStepContent();

        // Bottom
        bottomBar.removeAllViews();
        TextView stepLbl = new TextView(this);
        stepLbl.setText("Paso " + step + " de " + TOTAL);
        stepLbl.setTextSize(12); stepLbl.setTextColor(Color.parseColor("#64748B"));
        stepLbl.setGravity(Gravity.CENTER); stepLbl.setPadding(0, 0, 0, dp(8));
        bottomBar.addView(stepLbl);
        bottomBar.addView(buildNavRow());
    }

    private View buildHeader() {
        String[] titles = {
            "¿Qué estrategia usarás?", "Identidad de tu App", "Primera Impresión",
            "Estilo de Progreso", "Color de la App", "Navegación Inferior",
            "User Agent", "Selecciona Funciones", "¡Casi listo!"
        };
        String[] subs = {
            "Sube URL, HTML, Java, ZIP o varios archivos",
            "Dale a tu app una identidad única",
            "Un gran ícono hace tu app memorable",
            "Elige cómo se muestra el progreso de carga",
            "Selecciona el color principal de tu app",
            "Agrega tabs para navegar tu app",
            "Elige cómo los sitios ven tu navegador",
            "Selecciona las funciones que quieres incluir",
            "Cuéntanos el propósito de tu app"
        };

        LinearLayout card = new LinearLayout(this);
        card.setOrientation(LinearLayout.VERTICAL);
        card.setPadding(dp(20), dp(20), dp(20), dp(16));
        card.setGravity(Gravity.CENTER);
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(18));
        bg.setStroke(dp(1), Color.parseColor("#21262D")); card.setBackground(bg);

        TextView tv = new TextView(this); tv.setText(titles[step - 1]);
        tv.setTextSize(20); tv.setTypeface(Typeface.DEFAULT_BOLD);
        tv.setTextColor(Color.parseColor("#4F6EF7")); tv.setGravity(Gravity.CENTER);
        card.addView(tv);

        View div = new View(this); GradientDrawable divBg = new GradientDrawable();
        divBg.setColor(Color.parseColor("#4F6EF7"));
        LinearLayout.LayoutParams divLp = new LinearLayout.LayoutParams(dp(40), dp(2));
        divLp.setMargins(0, dp(10), 0, dp(10)); divLp.gravity = Gravity.CENTER_HORIZONTAL;
        div.setLayoutParams(divLp); div.setBackground(divBg); card.addView(div);

        TextView sv = new TextView(this); sv.setText(subs[step - 1]);
        sv.setTextSize(13); sv.setTextColor(Color.parseColor("#64748B"));
        sv.setGravity(Gravity.CENTER); card.addView(sv);
        return card;
    }

    private View buildNavRow() {
        LinearLayout row = new LinearLayout(this);
        row.setOrientation(LinearLayout.HORIZONTAL);

        if (step > 1) {
            TextView back = navBtn("← Volver", false);
            LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(0, dp(52), 1f);
            lp.setMargins(0, 0, dp(8), 0); back.setLayoutParams(lp);
            back.setOnClickListener(v -> { step--; renderStep(); });
            row.addView(back);
        }

        TextView next = navBtn(step == TOTAL ? "🚀 Crear APK" : "Continuar →", true);
        LinearLayout.LayoutParams lp2 = new LinearLayout.LayoutParams(
            step == 1 ? LinearLayout.LayoutParams.MATCH_PARENT : 0, dp(52), step == 1 ? 0f : 1f);
        next.setLayoutParams(lp2);
        next.setOnClickListener(v -> onNext());
        row.addView(next);
        return row;
    }

    private TextView navBtn(String label, boolean filled) {
        TextView b = new TextView(this); b.setText(label); b.setAllCaps(false);
        b.setTextSize(15); b.setGravity(Gravity.CENTER); b.setTypeface(Typeface.DEFAULT_BOLD);
        GradientDrawable bg = new GradientDrawable(); bg.setCornerRadius(dp(14));
        if (filled) {
            bg.setColors(new int[]{Color.parseColor("#4F6EF7"), Color.parseColor("#7C3AED")});
            bg.setOrientation(GradientDrawable.Orientation.LEFT_RIGHT);
            b.setTextColor(Color.WHITE);
        } else {
            bg.setColor(Color.parseColor("#161B22"));
            bg.setStroke(dp(2), Color.parseColor("#4F6EF7"));
            b.setTextColor(Color.parseColor("#4F6EF7"));
        }
        b.setBackground(bg); return b;
    }

    // ── Pasos ─────────────────────────────────────────────────────────────────
    private void buildStepContent() {
        switch (step) {
            case 1: buildStep1(); break;
            case 2: buildStep2(); break;
            case 3: buildStep3(); break;
            case 4: buildStep4(); break;
            case 5: buildStep5(); break;
            case 6: buildStep6(); break;
            case 7: buildStep7(); break;
            case 8: buildStep8(); break;
            case 9: buildStep9(); break;
        }
    }

    // Paso 1: Archivos
    private void buildStep1() {
        stepContent.addView(secLabel("📂  Archivos del proyecto"));

        LinearLayout btnRow = new LinearLayout(this);
        btnRow.setOrientation(LinearLayout.HORIZONTAL);
        btnRow.setPadding(0, 0, 0, dp(12));

        View bMulti = uploadBtn("Seleccionar\narchivos",
            "☕.java  📄.xml\n🔧.gradle  🖼 imagen",
            () -> withStoragePerm(() -> {
                Intent i = new Intent(Intent.ACTION_GET_CONTENT);
                i.setType("*/*");
                i.putExtra(Intent.EXTRA_ALLOW_MULTIPLE, true);
                startActivityForResult(Intent.createChooser(i, "Seleccionar archivos"), REQ_FILES);
            }));
        LinearLayout.LayoutParams lp1 = new LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f);
        lp1.setMargins(0, 0, dp(8), 0); bMulti.setLayoutParams(lp1);
        btnRow.addView(bMulti);

        View bZip = uploadBtn("Subir ZIP",
            "📦 Todo en\nun archivo",
            () -> withStoragePerm(() -> {
                Intent i = new Intent(Intent.ACTION_GET_CONTENT);
                i.setType("*/*");
                startActivityForResult(Intent.createChooser(i, "Seleccionar ZIP"), REQ_ZIP);
            }));
        bZip.setLayoutParams(new LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
        btnRow.addView(bZip);
        stepContent.addView(btnRow);

        if (files.isEmpty()) {
            TextView e = new TextView(this);
            e.setText("Ningún archivo seleccionado aún");
            e.setTextSize(13); e.setTextColor(Color.parseColor("#334155"));
            stepContent.addView(e);
        } else {
            for (int i = 0; i < files.size(); i++) {
                final int idx = i;
                stepContent.addView(fileRow(files.get(i), () -> {
                    files.remove(idx); renderStep();
                }));
            }
            TextView cnt = new TextView(this);
            cnt.setText("✅ " + files.size() + " archivo(s) listos");
            cnt.setTextSize(12); cnt.setTextColor(Color.parseColor("#22C55E"));
            cnt.setPadding(0, dp(6), 0, 0); stepContent.addView(cnt);
        }
    }

    // Paso 2: Nombre, Package, Versión
    private void buildStep2() {
        stepContent.addView(secLabel("📝  Información básica"));
        EditText etN = styledField("Nombre de la app");
        if (!appName.isEmpty()) etN.setText(appName);
        EditText etP = styledField("Package Name  (ej: com.empresa.miapp)");
        if (!packageName.isEmpty()) etP.setText(packageName);
        EditText etV = styledField("Versión");
        etV.setText(version.isEmpty() ? "1" : version);
        stepContent.addView(etN); stepContent.addView(etP); stepContent.addView(etV);
        etN.addTextChangedListener(tw(s -> appName = s));
        etP.addTextChangedListener(tw(s -> packageName = s));
        etV.addTextChangedListener(tw(s -> version = s));
    }

    // Paso 3: Ícono — pide permiso solo al tocar
    private void buildStep3() {
        stepContent.setGravity(Gravity.CENTER);

        ImageView ivIcon = new ImageView(this);
        int sz = dp(130);
        LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(sz, sz);
        lp.gravity = Gravity.CENTER_HORIZONTAL; lp.setMargins(0, dp(8), 0, dp(16));
        ivIcon.setLayoutParams(lp); ivIcon.setScaleType(ImageView.ScaleType.CENTER_CROP);
        GradientDrawable iBg = new GradientDrawable();
        iBg.setColor(Color.parseColor("#161B22")); iBg.setCornerRadius(dp(26));
        iBg.setStroke(dp(2), Color.parseColor("#4F6EF7")); ivIcon.setBackground(iBg);

        if (!iconPath.isEmpty()) {
            try {
                Bitmap b = BitmapFactory.decodeFile(iconPath);
                if (b != null) ivIcon.setImageBitmap(b);
            } catch (Exception ignored) {}
        }

        // Pide permiso solo cuando el usuario toca el ícono
        ivIcon.setOnClickListener(v ->
            withStoragePerm(() ->
                startActivityForResult(
                    new Intent(Intent.ACTION_PICK, MediaStore.Images.Media.EXTERNAL_CONTENT_URI),
                    REQ_ICON)));
        stepContent.addView(ivIcon);

        TextView hint = new TextView(this);
        hint.setText(iconPath.isEmpty()
            ? "Toca para seleccionar ícono\n(opcional)"
            : "✅ Ícono seleccionado\n(toca para cambiar)");
        hint.setTextSize(14);
        hint.setTextColor(iconPath.isEmpty()
            ? Color.parseColor("#64748B") : Color.parseColor("#22C55E"));
        hint.setGravity(Gravity.CENTER); stepContent.addView(hint);

        TextView skip = new TextView(this);
        skip.setText("Omitir — usar ícono predeterminado");
        skip.setTextSize(12); skip.setTextColor(Color.parseColor("#4F6EF7"));
        skip.setGravity(Gravity.CENTER); skip.setPadding(0, dp(12), 0, 0);
        skip.setOnClickListener(v -> { iconPath = ""; step++; renderStep(); });
        stepContent.addView(skip);
    }

    // Paso 4: Progress bar
    private void buildStep4() {
        stepContent.addView(secLabel("⏳  Estilo de carga"));
        String[][] opts = {
            {"⭕","Circular"}, {"─","Linear"},
            {"◌","Circular Infinite"}, {"—","Linear Infinite"}, {"⊘","None"}
        };
        for (String[] o : opts) {
            stepContent.addView(choiceRow(o[0] + "  " + o[1],
                progressStyle.equals(o[1]), () -> { progressStyle = o[1]; renderStep(); }));
        }
    }

    // Paso 5: Color
    private void buildStep5() {
        stepContent.addView(secLabel("🎨  Color principal"));

        View previewDot = new View(this);
        GradientDrawable pd = new GradientDrawable();
        pd.setShape(GradientDrawable.OVAL);
        try { pd.setColor(Color.parseColor(themeColor)); }
        catch (Exception e) { pd.setColor(Color.parseColor("#4F6EF7")); }
        previewDot.setBackground(pd);
        LinearLayout.LayoutParams dotLp = new LinearLayout.LayoutParams(dp(48), dp(48));
        dotLp.setMargins(0, 0, 0, dp(12)); previewDot.setLayoutParams(dotLp);
        stepContent.addView(previewDot);

        EditText etHex = styledField("Hex Color  (ej: #4F6EF7)");
        etHex.setText(themeColor);
        etHex.addTextChangedListener(tw(s -> {
            if (s.startsWith("#") && s.length() == 7) {
                try { themeColor = s; pd.setColor(Color.parseColor(s)); }
                catch (Exception ignored) {}
            }
        }));
        stepContent.addView(etHex);

        stepContent.addView(secLabel("Material Colors"));
        LinearLayout colorRow = new LinearLayout(this);
        colorRow.setOrientation(LinearLayout.HORIZONTAL);
        colorRow.setPadding(0, 0, 0, dp(8));
        String[] colors = {"#4F6EF7","#7C3AED","#EC4899","#EF4444","#F59E0B","#10B981","#06B6D4","#F97316"};
        for (String c : colors) {
            View dot = new View(this); int ds = dp(36);
            LinearLayout.LayoutParams cl = new LinearLayout.LayoutParams(ds, ds);
            cl.setMargins(0, 0, dp(8), 0); dot.setLayoutParams(cl);
            GradientDrawable db = new GradientDrawable();
            db.setShape(GradientDrawable.OVAL); db.setColor(Color.parseColor(c));
            if (c.equals(themeColor)) db.setStroke(dp(3), Color.WHITE);
            dot.setBackground(db);
            dot.setOnClickListener(v -> {
                themeColor = c; etHex.setText(c);
                pd.setColor(Color.parseColor(c)); renderStep();
            });
            colorRow.addView(dot);
        }
        stepContent.addView(colorRow);
    }

    // Paso 6: Bottom nav
    private void buildStep6() {
        stepContent.addView(secLabel("🗂  Navegación inferior"));
        LinearLayout row = new LinearLayout(this);
        row.setOrientation(LinearLayout.HORIZONTAL);
        row.setGravity(Gravity.CENTER_VERTICAL);
        row.setPadding(dp(16), dp(16), dp(16), dp(16));
        GradientDrawable rb = new GradientDrawable();
