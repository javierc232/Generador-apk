    // Paso 8: Features
    private void buildStep8() {
        stepContent.addView(secLabel("⚡  Funciones"));
        String[][] cats = {
            {"Navigation & UI","Top App Bar","Edge to Edge","Splash Screen","Desktop Mode","Multi Windows","Ad Blocker"},
            {"Loading & Progress","Custom Progress","Shimmer Effect"},
            {"Connectivity","Offline Mode","Push Notifications"}
        };
        for (String[] cat : cats) {
            TextView catLbl = new TextView(this); catLbl.setText(cat[0]);
            catLbl.setTextSize(13); catLbl.setTypeface(Typeface.DEFAULT_BOLD);
            catLbl.setTextColor(Color.parseColor("#94A3B8"));
            catLbl.setPadding(0, dp(12), 0, dp(6)); stepContent.addView(catLbl);
            LinearLayout grid = new LinearLayout(this);
            grid.setOrientation(LinearLayout.HORIZONTAL);
            LinearLayout col1 = new LinearLayout(this); col1.setOrientation(LinearLayout.VERTICAL);
            col1.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
            LinearLayout col2 = new LinearLayout(this); col2.setOrientation(LinearLayout.VERTICAL);
            col2.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
            grid.addView(col1); grid.addView(col2);
            for (int i = 1; i < cat.length; i++) {
                final String feat = cat[i]; boolean sel = features.contains(feat);
                TextView btn = new TextView(this); btn.setText(feat);
                btn.setTextSize(12); btn.setGravity(Gravity.CENTER);
                btn.setPadding(dp(8), dp(12), dp(8), dp(12));
                GradientDrawable fb = new GradientDrawable(); fb.setCornerRadius(dp(10));
                fb.setColor(sel ? Color.parseColor("#1A2563") : Color.parseColor("#161B22"));
                fb.setStroke(dp(2), sel ? Color.parseColor("#4F6EF7") : Color.parseColor("#21262D"));
                btn.setBackground(fb);
                btn.setTextColor(sel ? Color.parseColor("#4F6EF7") : Color.parseColor("#64748B"));
                LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
                lp.setMargins(dp(4), dp(4), dp(4), dp(4)); btn.setLayoutParams(lp);
                btn.setOnClickListener(v -> {
                    if (features.contains(feat)) features.remove(feat); else features.add(feat);
                    renderStep();
                });
                if (i % 2 == 1) col1.addView(btn); else col2.addView(btn);
            }
            stepContent.addView(grid);
        }
    }

    // Paso 9: Propósito
    private void buildStep9() {
        stepContent.addView(secLabel("🎯  Propósito de la app"));
        String[][] opts = {
            {"🏢","Business"}, {"👤","Personal Use"}, {"🎓","Education"},
            {"💼","Portfolio"}, {"🛒","E-commerce"}, {"🎮","Entertainment"}
        };
        for (String[] o : opts) {
            stepContent.addView(choiceRow(o[0] + "  " + o[1],
                purpose.equals(o[1]), () -> { purpose = o[1]; renderStep(); }));
        }
    }

    // ── Navegación ────────────────────────────────────────────────────────────
    private void onNext() {
        if (step == 1 && files.isEmpty()) { toast("Agrega al menos un archivo"); return; }
        if (step == 2 && appName.isEmpty()) { toast("Escribe el nombre de la app"); return; }
        if (step < TOTAL) { step++; renderStep(); }
        else submitProject();
    }

    private void submitProject() {
        if (packageName.isEmpty())
            packageName = "com.generado." + appName.toLowerCase().replaceAll("[^a-z0-9]", "");
        if (version.isEmpty()) version = "1";

        // Overlay de carga
        FrameLayout overlay = new FrameLayout(this);
        overlay.setBackgroundColor(Color.parseColor("#CC000000")); overlay.setClickable(true);
        LinearLayout box = new LinearLayout(this);
        box.setOrientation(LinearLayout.VERTICAL); box.setGravity(Gravity.CENTER);
        box.setPadding(dp(32), dp(32), dp(32), dp(32));
        FrameLayout.LayoutParams boxLp = new FrameLayout.LayoutParams(dp(260), LinearLayout.LayoutParams.WRAP_CONTENT);
        boxLp.gravity = Gravity.CENTER; box.setLayoutParams(boxLp);
        GradientDrawable boxBg = new GradientDrawable();
        boxBg.setColor(Color.parseColor("#161B22")); boxBg.setCornerRadius(dp(20));
        box.setBackground(boxBg);
        TextView msg = new TextView(this);
        msg.setText("🚀 Subiendo a GitHub...\n\nEsto puede tardar unos segundos.");
        msg.setTextSize(14); msg.setTextColor(Color.WHITE); msg.setGravity(Gravity.CENTER);
        box.addView(msg); overlay.addView(box); root.addView(overlay);

        final String fName = appName, fPkg = packageName, fVer = version;
        final List<ProjectFile> fc = new ArrayList<>(files);

        new Thread(() -> {
            try {
                boolean ok = new GitHubUploader().upload(
                    projectId, fName, fPkg, fVer, themeColor, iconPath,
                    fc, progressStyle, bottomNav, userAgent, features, purpose);
                new Handler(Looper.getMainLooper()).post(() -> {
                    root.removeView(overlay);
                    if (ok) {
                        saveProject(fName, fPkg, fVer);
                        GitHubUploader.poll(this, projectId, fName);
                        new AlertDialog.Builder(this).setTitle("🚀 ¡Enviado a GitHub!")
                            .setMessage("\"" + fName + "\" se está compilando.\n\nRecibirás una notificación cuando tu APK esté lista para instalar.")
                            .setPositiveButton("Ver progreso", (d, w) -> {
                                startActivity(new Intent(Intent.ACTION_VIEW,
                                    Uri.parse("https://github.com/javierc232/Generador-apk/actions")));
                                finish();
                            })
                            .setNegativeButton("Volver al inicio", (d, w) -> finish())
                            .setCancelable(false).show();
                    } else toast("Error al conectar con GitHub. Verifica el token.");
                });
            } catch (Exception e) {
                new Handler(Looper.getMainLooper()).post(() -> {
                    root.removeView(overlay); toast("Error: " + e.getMessage());
                });
            }
        }).start();
    }

    private void saveProject(String name, String pkg, String ver) {
        SharedPreferences sp = getSharedPreferences(PREFS, MODE_PRIVATE);
        try {
            JSONArray a = new JSONArray(sp.getString(KEY_PROJ, "[]"));
            JSONObject o = new JSONObject();
            o.put("id", projectId); o.put("name", name); o.put("package", pkg);
            o.put("version", ver); o.put("color", themeColor); o.put("iconPath", iconPath);
            o.put("fileCount", files.size()); o.put("status", "Compilando...");
            a.put(o); sp.edit().putString(KEY_PROJ, a.toString()).apply();
        } catch (Exception ignored) {}
    }

    // ── Permisos — solo cuando el usuario toca algo que lo necesita ───────────
    private void withStoragePerm(Runnable action) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
            if (Environment.isExternalStorageManager()) {
                action.run();
            } else {
                pendingAction = action;
                new AlertDialog.Builder(this)
                    .setTitle("Permiso necesario")
                    .setMessage("Para acceder a tus archivos necesitamos el permiso de almacenamiento.")
                    .setPositiveButton("Dar permiso", (d, w) -> {
                        try {
                            startActivityForResult(new Intent(
                                Settings.ACTION_MANAGE_APP_ALL_FILES_ACCESS_PERMISSION,
                                Uri.parse("package:" + getPackageName())), REQ_STORAGE);
                        } catch (Exception e) {
                            startActivityForResult(new Intent(
                                Settings.ACTION_MANAGE_ALL_FILES_ACCESS_PERMISSION), REQ_STORAGE);
                        }
                    })
                    .setNegativeButton("Cancelar", null).show();
            }
        } else if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.READ_EXTERNAL_STORAGE)
                    == PackageManager.PERMISSION_GRANTED) {
                action.run();
            } else {
                pendingAction = action;
                ActivityCompat.requestPermissions(this,
                    new String[]{Manifest.permission.READ_EXTERNAL_STORAGE}, REQ_STORAGE);
            }
        } else {
            action.run();
        }
    }

    @Override
    public void onRequestPermissionsResult(int req, @NonNull String[] perms, @NonNull int[] results) {
        super.onRequestPermissionsResult(req, perms, results);
        if (req == REQ_STORAGE && results.length > 0
                && results[0] == PackageManager.PERMISSION_GRANTED && pendingAction != null) {
            Runnable action = pendingAction; pendingAction = null; action.run();
        }
    }

    @Override
    protected void onActivityResult(int req, int res, Intent data) {
        super.onActivityResult(req, res, data);

        // Regresó de la pantalla de permisos de sistema
        if (req == REQ_STORAGE) {
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R
                    && Environment.isExternalStorageManager() && pendingAction != null) {
                Runnable action = pendingAction; pendingAction = null; action.run();
            }
            return;
        }

        if (res != Activity.RESULT_OK || data == null) return;

        if (req == REQ_ICON) {
            String p = copyUri(data.getData(), "icon_" + System.currentTimeMillis() + ".png");
            if (p != null) { iconPath = p; renderStep(); }
            return;
        }

        List<Uri> uris = new ArrayList<>();
        if (data.getClipData() != null)
            for (int i = 0; i < data.getClipData().getItemCount(); i++)
                uris.add(data.getClipData().getItemAt(i).getUri());
        else if (data.getData() != null) uris.add(data.getData());

        for (Uri uri : uris) {
            String name = getFileName(uri);
            String path = copyUri(uri, name);
            if (path != null) {
                boolean dup = false;
                for (ProjectFile f : files) if (f.fileName.equals(name)) { dup = true; break; }
                if (!dup) files.add(new ProjectFile(path, name));
            }
        }
        renderStep();
    }

    private String getFileName(Uri uri) {
        String name = "file_" + System.currentTimeMillis();
        try {
            android.database.Cursor c = getContentResolver().query(uri,
                new String[]{android.provider.OpenableColumns.DISPLAY_NAME}, null, null, null);
            if (c != null && c.moveToFirst()) { name = c.getString(0); c.close(); }
        } catch (Exception ignored) {}
        return name;
    }

    private String copyUri(Uri uri, String name) {
        try {
            InputStream is = getContentResolver().openInputStream(uri);
            if (is == null) return null;
            File dest = new File(getCacheDir(), name);
            FileOutputStream fos = new FileOutputStream(dest);
            byte[] buf = new byte[8192]; int len;
            while ((len = is.read(buf)) > 0) fos.write(buf, 0, len);
            fos.close(); is.close(); return dest.getAbsolutePath();
        } catch (Exception e) { return null; }
    }

    // ── UI helpers ────────────────────────────────────────────────────────────
    private View uploadBtn(String title, String desc, Runnable action) {
        LinearLayout b = new LinearLayout(this);
        b.setOrientation(LinearLayout.VERTICAL); b.setPadding(dp(14), dp(14), dp(14), dp(14));
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(14));
        bg.setStroke(dp(2), Color.parseColor("#21262D")); b.setBackground(bg);
        b.setOnClickListener(v -> action.run());
        TextView t = new TextView(this); t.setText(title); t.setTextSize(13);
        t.setTypeface(Typeface.DEFAULT_BOLD); t.setTextColor(Color.WHITE); b.addView(t);
        TextView d = new TextView(this); d.setText(desc); d.setTextSize(11);
        d.setTextColor(Color.parseColor("#64748B")); d.setPadding(0, dp(4), 0, 0); b.addView(d);
        return b;
    }

    private View fileRow(ProjectFile pf, Runnable remove) {
        LinearLayout row = new LinearLayout(this);
        row.setOrientation(LinearLayout.HORIZONTAL); row.setGravity(Gravity.CENTER_VERTICAL);
        row.setPadding(dp(12), dp(10), dp(12), dp(10));
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(10));
        bg.setStroke(dp(1), Color.parseColor("#21262D")); row.setBackground(bg);
        LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        lp.setMargins(0, 0, 0, dp(6)); row.setLayoutParams(lp);
        TextView em = new TextView(this); em.setText(pf.emoji()); em.setTextSize(16);
        em.setPadding(0, 0, dp(8), 0); row.addView(em);
        LinearLayout txts = new LinearLayout(this); txts.setOrientation(LinearLayout.VERTICAL);
        txts.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
        TextView tn = new TextView(this); tn.setText(pf.fileName); tn.setTextSize(13);
        tn.setTextColor(Color.WHITE); tn.setTypeface(Typeface.DEFAULT_BOLD); txts.addView(tn);
        TextView td = new TextView(this); td.setText("→ " + pf.remotePath); td.setTextSize(11);
        td.setTextColor(Color.parseColor("#4F6EF7")); td.setPadding(0, dp(2), 0, 0); txts.addView(td);
        row.addView(txts);
        TextView rm = new TextView(this); rm.setText("✕"); rm.setTextSize(14);
        rm.setTextColor(Color.parseColor("#EF4444")); rm.setPadding(dp(8), 0, 0, 0);
        rm.setOnClickListener(v -> remove.run()); row.addView(rm);
        return row;
    }

    private View choiceRow(String label, boolean selected, Runnable action) {
        LinearLayout row = new LinearLayout(this);
        row.setOrientation(LinearLayout.HORIZONTAL); row.setGravity(Gravity.CENTER_VERTICAL);
        row.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        lp.setMargins(0, 0, 0, dp(8)); row.setLayoutParams(lp);
        GradientDrawable bg = new GradientDrawable(); bg.setCornerRadius(dp(12));
        bg.setColor(selected ? Color.parseColor("#1A2563") : Color.parseColor("#161B22"));
        bg.setStroke(dp(2), selected ? Color.parseColor("#4F6EF7") : Color.parseColor("#21262D"));
        row.setBackground(bg);
        TextView lbl = new TextView(this); lbl.setText(label); lbl.setTextSize(14);
        lbl.setTextColor(selected ? Color.parseColor("#4F6EF7") : Color.WHITE);
        lbl.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
        row.addView(lbl);
        if (selected) {
            TextView ch = new TextView(this); ch.setText("✓"); ch.setTextSize(16);
            ch.setTextColor(Color.parseColor("#4F6EF7")); row.addView(ch);
        }
        row.setOnClickListener(v -> action.run()); return row;
    }

    private TextView secLabel(String text) {
        TextView tv = new TextView(this); tv.setText(text); tv.setTextSize(12);
        tv.setTypeface(Typeface.DEFAULT_BOLD); tv.setTextColor(Color.parseColor("#94A3B8"));
        tv.setPadding(0, dp(4), 0, dp(10)); return tv;
    }

    private EditText styledField(String hint) {
        EditText et = new EditText(this); et.setHint(hint);
        et.setHintTextColor(Color.parseColor("#334155")); et.setTextColor(Color.WHITE);
        et.setTextSize(14); et.setPadding(dp(16), dp(14), dp(16), dp(14));
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(12));
        bg.setStroke(dp(1), Color.parseColor("#21262D")); et.setBackground(bg);
        LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
        lp.setMargins(0, 0, 0, dp(10)); et.setLayoutParams(lp);
        return et;
    }

    private TextWatcher tw(Consumer<String> fn) {
        return new TextWatcher() {
            public void beforeTextChanged(CharSequence s, int a, int b, int c) {}
            public void onTextChanged(CharSequence s, int a, int b, int c) { fn.accept(s.toString().trim()); }
            public void afterTextChanged(Editable s) {}
        };
    }

    private void toast(String m) { Toast.makeText(this, m, Toast.LENGTH_SHORT).show(); }
    private int dp(int v) {
        return (int) TypedValue.applyDimension(
            TypedValue.COMPLEX_UNIT_DIP, v, getResources().getDisplayMetrics());
    }
}

// ═════════════════════════════════════════════════════════════════════════════
//  GITHUB UPLOADER
// ═════════════════════════════════════════════════════════════════════════════
class GitHubUploader {

    private static final String OWNER    = "javierc232";
    private static final String REPO     = "Generador-apk";
    // ⚠️ Reemplaza con tu Personal Access Token (scopes: repo + workflow)
    private static final String TOKEN    = "TU_GITHUB_TOKEN_AQUI";
    private static final String WORKFLOW = "build.yml";
    private static final String API      = "https://api.github.com";
    private static final String CH       = "apk_ready";
    private static final String PREFS    = "wf_prefs";
    private static final String KEY_PROJ = "saved_projects";

    public boolean upload(String id, String name, String pkg, String ver, String color,
                          String iconPath, List<ProjectFile> files, String progressStyle,
                          boolean bottomNav, String userAgent, List<String> features,
                          String purpose) throws Exception {
        JSONObject cfg = new JSONObject();
        cfg.put("projectId", id); cfg.put("appName", name); cfg.put("package", pkg);
        cfg.put("version", ver); cfg.put("color", color); cfg.put("progressStyle", progressStyle);
        cfg.put("bottomNav", bottomNav); cfg.put("userAgent", userAgent); cfg.put("purpose", purpose);
        JSONArray fa = new JSONArray(); for (ProjectFile f : files) fa.put(f.remotePath); cfg.put("files", fa);
        JSONArray feat = new JSONArray(); for (String f : features) feat.put(f); cfg.put("features", feat);
        if (!putText("projects/" + id + "/config.json", cfg.toString(2), "Config: " + name)) return false;
        for (ProjectFile f : files) putBin(f.localPath, "projects/" + id + "/" + f.remotePath, f.type + ": " + f.fileName);
        if (!iconPath.isEmpty() && new File(iconPath).exists()) putBin(iconPath, "projects/" + id + "/icon.png", "Icon");
        JSONObject body = new JSONObject(); body.put("ref", "main");
        JSONObject inp = new JSONObject(); inp.put("project_id", id); inp.put("app_name", name); body.put("inputs", inp);
        int code = req("POST", "/repos/" + OWNER + "/" + REPO + "/actions/workflows/" + WORKFLOW + "/dispatches", body.toString());
        return code == 204 || code == 200;
    }

    private boolean putText(String path, String content, String msg) throws Exception {
        return putBytes(path, content.getBytes(StandardCharsets.UTF_8), msg);
    }
    private boolean putBin(String local, String remote, String msg) {
        try { File f = new File(local); if (!f.exists()) return false; FileInputStream fis = new FileInputStream(f); byte[] d = new byte[(int)f.length()]; fis.read(d); fis.close(); return putBytes(remote, d, msg); } catch (Exception e) { return false; }
    }
    private boolean putBytes(String path, byte[] data, String msg) throws Exception {
        String enc = Base64.encodeToString(data, Base64.NO_WRAP); String sha = sha(path);
        JSONObject b = new JSONObject(); b.put("message", msg); b.put("content", enc); if (sha != null) b.put("sha", sha);
        int code = req("PUT", "/repos/" + OWNER + "/" + REPO + "/contents/" + path, b.toString()); return code == 200 || code == 201;
    }
    private String sha(String path) { try { URL url = new URL(API + "/repos/" + OWNER + "/" + REPO + "/contents/" + path); HttpURLConnection c = conn(url, "GET"); if (c.getResponseCode() == 200) return new JSONObject(read(c)).optString("sha", null); } catch (Exception ignored) {} return null; }
    private int req(String method, String ep, String body) throws Exception { URL url = new URL(API + ep); HttpURLConnection c = conn(url, method); if (body != null) { c.setDoOutput(true); byte[] b = body.getBytes(StandardCharsets.UTF_8); c.setFixedLengthStreamingMode(b.length); c.getOutputStream().write(b); } int code = c.getResponseCode(); c.disconnect(); return code; }
    private HttpURLConnection conn(URL url, String method) throws Exception { HttpURLConnection c = (HttpURLConnection)url.openConnection(); c.setRequestMethod(method); c.setRequestProperty("Authorization", "Bearer " + TOKEN); c.setRequestProperty("Accept", "application/vnd.github+json"); c.setRequestProperty("Content-Type", "application/json"); c.setRequestProperty("X-GitHub-Api-Version", "2022-11-28"); c.setConnectTimeout(20000); c.setReadTimeout(20000); return c; }
    private String read(HttpURLConnection c) throws Exception { BufferedReader br = new BufferedReader(new InputStreamReader(c.getInputStream(), StandardCharsets.UTF_8)); StringBuilder sb = new StringBuilder(); String l; while ((l = br.readLine()) != null) sb.append(l); br.close(); return sb.toString(); }

    public static void poll(Context ctx, String id, String name) {
        Handler h = new Handler(Looper.getMainLooper()); Runnable[] r = new Runnable[1];
        r[0] = () -> new Thread(() -> { try {
            String st = new GitHubUploader().checkRun(id);
            new Handler(Looper.getMainLooper()).post(() -> {
                if ("success".equals(st)) { updateSt(ctx, id, "Completado"); notif(ctx, name, true); }
                else if ("failure".equals(st) || "cancelled".equals(st)) { updateSt(ctx, id, "Error al compilar"); notif(ctx, name, false); }
                else h.postDelayed(r[0], 30_000);
            });
        } catch (Exception e) { h.postDelayed(r[0], 30_000); } }).start();
        h.postDelayed(r[0], 60_000);
    }

    private String checkRun(String id) { try { URL url = new URL(API + "/repos/" + OWNER + "/" + REPO + "/actions/runs?event=workflow_dispatch&per_page=15"); HttpURLConnection c = conn(url, "GET"); if (c.getResponseCode() == 200) { JSONArray runs = new JSONObject(read(c)).getJSONArray("workflow_runs"); for (int i = 0; i < runs.length(); i++) { JSONObject run = runs.getJSONObject(i); if (run.optString("head_commit_message","").contains(id) || run.optString("name","").contains(id)) { if ("completed".equals(run.optString("status",""))) return run.optString("conclusion","failure"); return run.optString("status","in_progress"); } } } } catch (Exception ignored) {} return "in_progress"; }
    private static void updateSt(Context ctx, String id, String st) { SharedPreferences sp = ctx.getSharedPreferences(PREFS, Context.MODE_PRIVATE); try { JSONArray a = new JSONArray(sp.getString(KEY_PROJ,"[]")); for (int i = 0; i < a.length(); i++) if (a.getJSONObject(i).optString("id").equals(id)) { a.getJSONObject(i).put("status", st); break; } sp.edit().putString(KEY_PROJ, a.toString()).apply(); } catch (Exception ignored) {} }
    private static void notif(Context ctx, String name, boolean ok) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) ((NotificationManager)ctx.getSystemService(Context.NOTIFICATION_SERVICE)).createNotificationChannel(new NotificationChannel(CH, "APK Lista", NotificationManager.IMPORTANCE_HIGH));
        PendingIntent pi = PendingIntent.getActivity(ctx, 0, new Intent(Intent.ACTION_VIEW, Uri.parse("https://github.com/javierc232/Generador-apk/actions")), PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);
        NotificationCompat.Builder b = new NotificationCompat.Builder(ctx, CH).setSmallIcon(ok ? android.R.drawable.stat_sys_download_done : android.R.drawable.stat_notify_error).setContentTitle(ok ? "✅ ¡Tu APK está lista!" : "❌ Error al compilar").setContentText(ok ? "\"" + name + "\" lista para instalar." : "\"" + name + "\" tuvo un error. Revisa GitHub Actions.").setPriority(NotificationCompat.PRIORITY_HIGH).setAutoCancel(true).setContentIntent(pi);
        ((NotificationManager)ctx.getSystemService(Context.NOTIFICATION_SERVICE)).notify(name.hashCode(), b.build());
    }
}
