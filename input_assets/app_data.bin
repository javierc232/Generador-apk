<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editor de Código Pro</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #eceff1; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: white; width: 90%; max-width: 850px; padding: 2rem; border-radius: 15px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); }
        h2 { color: #37474f; margin-bottom: 1.5rem; text-align: center; }
        textarea { width: 100%; height: 350px; background: #1e1e1e; color: #d4d4d4; border: none; border-radius: 8px; padding: 15px; font-family: 'Consolas', monospace; font-size: 14px; box-sizing: border-box; outline: none; }
        .controls { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 1.5rem; }
        input, select, button { flex: 1; min-width: 150px; padding: 12px; border: 1px solid #cfd8dc; border-radius: 6px; font-size: 14px; }
        button { background: #2196f3; color: white; border: none; font-weight: bold; cursor: pointer; transition: 0.3s; }
        button:hover { background: #1976d2; }
        button:active { transform: scale(0.98); }
    </style>
</head>
<body>

<div class="card">
    <h2>Guardar mi Código</h2>
    <textarea id="txtCodigo" placeholder="Escribe tu código aquí..."></textarea>
    
    <div class="controls">
        <input type="text" id="nombreArchivo" placeholder="Nombre del archivo" value="mi_proyecto">
        <select id="tipoArchivo">
            <option value="html">HTML (.html)</option>
            <option value="java">Java (.java)</option>
            <option value="zip">Comprimir (.zip)</option>
        </select>
        <button id="btnDescargar">Descargar ahora</button>
    </div>
</div>

<script>
    document.getElementById('btnDescargar').addEventListener('click', function() {
        const codigo = document.getElementById('txtCodigo').value;
        const nombre = document.getElementById('nombreArchivo').value.trim() || 'archivo';
        const formato = document.getElementById('tipoArchivo').value;

        if (!codigo) {
            alert("⚠️ Por favor, escribe algún código antes de descargar.");
            return;
        }

        try {
            if (formato === 'zip') {
                if (typeof JSZip === "undefined") {
                    alert("❌ Error: La librería de compresión no se ha cargado. Verifica tu conexión a internet.");
                    return;
                }
                descargarComoZip(nombre, codigo);
            } else {
                descargarComoTexto(nombre + '.' + formato, codigo);
            }
        } catch (err) {
            console.error(err);
            alert("❌ Ocurrió un error al generar el archivo: " + err.message);
        }
    });

    function descargarComoTexto(nombreFull, contenido) {
        const blob = new Blob([contenido], { type: 'text/plain;charset=utf-8' });
        const link = document.createElement('a');
        const url = URL.createObjectURL(blob);
        
        link.href = url;
        link.download = nombreFull;
        document.body.appendChild(link);
        link.click();
        
        setTimeout(() => {
            document.body.removeChild(link);
            window.URL.revokeObjectURL(url);
        }, 100);
    }

    function descargarComoZip(nombreBase, contenido) {
        const zip = new JSZip();
        // Agregamos el archivo dentro del zip con su extensión correspondiente
        zip.file(nombreBase + ".txt", contenido);

        zip.generateAsync({ type: "blob" }).then(function(blob) {
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = nombreBase + ".zip";
            document.body.appendChild(link);
            link.click();

            setTimeout(() => {
                document.body.removeChild(link);
                window.URL.revokeObjectURL(url);
            }, 100);
        });
    }
</script>

</body>
</html>
