<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebForge Pro — Final</title>
    <style>
        :root { --blue: #3b82f6; --green: #10b981; --bg: #f3f4f6; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg); margin: 0; padding: 20px; display: flex; justify-content: center; }
        .card { background: white; width: 100%; max-width: 450px; border-radius: 20px; padding: 25px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #1f2937; margin-bottom: 20px; }
        .field { margin-bottom: 15px; }
        label { display: block; font-size: 12px; font-weight: bold; color: #6b7280; text-transform: uppercase; margin-bottom: 5px; }
        .inp { width: 100%; padding: 12px; border: 2px solid #e5e7eb; border-radius: 10px; box-sizing: border-box; transition: 0.3s; }
        .inp:focus { border-color: var(--blue); outline: none; }
        .btn { width: 100%; padding: 15px; border-radius: 12px; border: none; font-weight: bold; cursor: pointer; transition: 0.3s; margin-top: 10px; }
        .btn-blue { background: var(--blue); color: white; }
        .btn-blue:hover { background: #2563eb; }
        .btn-file { background: #f9fafb; border: 2px dashed #d1d5db; color: #4b5563; }
        .status-box { margin-top: 20px; background: #111827; border-radius: 12px; padding: 15px; color: #34d399; font-family: monospace; font-size: 13px; min-height: 100px; }
        .log-line { margin-bottom: 5px; display: flex; align-items: center; }
        .log-line.error { color: #f87171; }
        .loader { width: 12px; height: 12px; border: 2px solid #34d399; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; margin-right: 10px; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: bold; margin-left: 8px; }
        .badge-html { background: #dbeafe; color: #1d4ed8; }
        .badge-java { background: #dcfce7; color: #15803d; }
        .pkg-preview { font-size: 11px; color: #9ca3af; margin-top: 5px; font-family: monospace; }
    </style>
</head>
<body>

<div class="card">
    <h2>WebForge Pro v7</h2>

    <div class="field">
        <label>Nombre del Proyecto</label>
        <input type="text" id="appName" class="inp" placeholder="Mi Increible App" oninput="updatePkgPreview()">
        <div class="pkg-preview" id="pkgPreview">Package: com.webforge.app</div>
    </div>

    <div class="field">
        <label>Contenido (HTML, ZIP o Java)</label>
        <button class="btn btn-file" onclick="document.getElementById('fileIn').click()" id="fileLabel">📁 Seleccionar Archivo</button>
        <input type="file" id="fileIn" hidden onchange="processFile(this)">
    </div>

    <div class="field">
        <label>Icono de App (Opcional)</label>
        <button class="btn btn-file" onclick="document.getElementById('iconIn').click()" id="iconLabel">🖼️ Seleccionar Icono</button>
        <input type="file" id="iconIn" hidden accept="image/*" onchange="processIcon(this)">
    </div>

    <button class="btn btn-blue" onclick="initBuild()">🚀 COMPILAR APK</button>

    <div class="status-box" id="console">
        <div class="log-line">> Esperando inicio...</div>
    </div>
</div>

<script>
    const USER = "javierc232";
    const REPO = "Generador-apk";
    let appData = { file: "", icon: "", fileType: "html" };

    function getSafePkg(name) {
        const safe = name.toLowerCase().replace(/[^a-z0-9]/g, '') || "app";
        return "com.webforge." + safe;
    }

    function updatePkgPreview() {
        const name = document.getElementById('appName').value || "app";
        document.getElementById('pkgPreview').innerText = "Package: " + getSafePkg(name);
    }

    function log(msg, isError = false) {
        const con = document.getElementById('console');
        const div = document.createElement('div');
        div.className = `log-line ${isError ? 'error' : ''}`;
        div.innerHTML = (isError ? '❌ ' : '✅ ') + msg;
        con.appendChild(div);
        con.scrollTop = con.scrollHeight;
    }

    function processFile(input) {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (e) => {
            appData.file = e.target.result.split(',')[1];

            if (file.name.endsWith('.java')) {
                appData.fileType = 'java';
                document.getElementById('fileLabel').innerHTML = '✅ ' + file.name + ' <span class="badge badge-java">JAVA</span>';
                log("Archivo Java cargado.");
            } else {
                appData.fileType = 'html';
                document.getElementById('fileLabel').innerHTML = '✅ ' + file.name + ' <span class="badge badge-html">HTML</span>';
                log("Archivo HTML/ZIP cargado.");
            }
        };
        reader.readAsDataURL(file);
    }

    function processIcon(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (e) => {
            appData.icon = e.target.result.split(',')[1];
            document.getElementById('iconLabel').innerText = "✅ Icono listo";
            log("Icono procesado.");
        };
        reader.readAsDataURL(file);
    }

    async function gitPut(path, content, token) {
        const url = `https://api.github.com/repos/${USER}/${REPO}/contents/${path}`;
        let sha = null;
        const check = await fetch(url, { headers: { "Authorization": `token ${token}` } });
        if (check.ok) { const d = await check.json(); sha = d.sha; }
        return fetch(url, {
            method: "PUT",
            headers: { "Authorization": `token ${token}`, "Content-Type": "application/json" },
            body: JSON.stringify({ message: "Update assets", content: content, sha: sha })
        });
    }

    async function initBuild() {
        const token = localStorage.getItem('wf_token') || prompt("Introduce tu GitHub Personal Token:");
        if (!token) return;
        localStorage.setItem('wf_token', token);

        if (!appData.file) {
            log("No has seleccionado ningún archivo.", true);
            return;
        }

        const appName = document.getElementById('appName').value.trim() || "WebForgeApp";
        const pkgName = getSafePkg(appName);

        document.getElementById('console').innerHTML = '<div class="log-line"><div class="loader"></div> Conectando con GitHub...</div>';

        try {
            await gitPut("input_assets/app_data.bin", appData.file, token);
            log("Archivo enviado (" + appData.fileType.toUpperCase() + ").");

            if (appData.icon) {
                await gitPut("input_assets/icon.png", appData.icon, token);
                log("Icono enviado.");
            }

            const config = {
                name: appName,
                package: pkgName,
                type: appData.fileType
            };
            await gitPut("input_assets/config.json", btoa(JSON.stringify(config)), token);
            log("Configuración enviada.");
            log("Nombre: " + appName);
            log("Package: " + pkgName);

            const dispatch = await fetch(`https://api.github.com/repos/${USER}/${REPO}/dispatches`, {
                method: "POST",
                headers: {
                    "Authorization": `token ${token}`,
                    "Accept": "application/vnd.github.v3+json"
                },
                body: JSON.stringify({ event_type: "build_app", client_payload: config })
            });

            if (dispatch.ok) {
                log("¡Motor arrancado! Compilando...");
                log("Espera 2-4 minutos...");
                startPolling(token);
            } else {
                throw "Error al disparar el workflow. Verifica tu token.";
            }

        } catch (err) {
            log(err, true);
        }
    }

    function startPolling(token) {
        const startTime = Date.now();
        const interval = setInterval(async () => {
            try {
                const res = await fetch(`https://api.github.com/repos/${USER}/${REPO}/releases/latest`, {
                    headers: { "Authorization": `token ${token}` },
                    cache: 'no-store'
                });

                if (res.ok) {
                    const data = await res.json();
                    const apk = data.assets.find(a => a.name.endsWith('.apk'));
                    const releaseTime = new Date(data.created_at).getTime();

                    if (apk && releaseTime > startTime) {
                        clearInterval(interval);
                        log("¡APK GENERADA CON ÉXITO! Descargando...");
                        window.location.href = apk.browser_download_url;
                    } else {
                        log("Compilando... espera.");
                    }
                }
            } catch(e) {}
        }, 15000);

        setTimeout(() => {
            clearInterval(interval);
            log("Tiempo agotado. Revisa Actions en GitHub.", true);
        }, 600000);
    }
</script>

</body>
</html>
