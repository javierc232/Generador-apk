<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>WebForge Pro — Constructor</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f8fafc; --white:#ffffff; --blue:#3b82f6; --blue-d:#1d4ed8; --blue-l:#eff6ff;
  --text:#1e293b; --muted:#64748b; --border:#e2e8f0; --green:#10b981;
  --shadow:0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:15px;overflow-x:hidden}

.view{display:none;min-height:100vh;flex-direction:column}
.view.active{display:flex}
.navbar{background:var(--white);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:65px;position:sticky;top:0;z-index:200}
.logo{font-weight:800;font-size:20px;letter-spacing:-0.5px}.logo span{color:var(--blue)}

.wiz-dots{display:flex;justify-content:center;gap:6px;padding:20px 0}
.wiz-dot{width:8px;height:8px;border-radius:50%;background:#cbd5e1;transition:0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)}
.wiz-dot.on{background:var(--blue);width:30px;border-radius:10px}

.wiz-body{padding:0 20px 140px;flex:1;max-width:500px;margin:0 auto;width:100%}
.wiz-card{background:var(--white);border-radius:28px;padding:35px 25px;text-align:center;margin-bottom:20px;border:1px solid var(--border);box-shadow:var(--shadow)}
.wiz-card h2{color:var(--text);font-size:24px;font-weight:800;margin-bottom:10px}
.wiz-card p{color:var(--muted);font-size:14px;margin-bottom:20px}

.field{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;text-align:left}
.field label{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px}
.inp{width:100%;background:var(--bg);border:2px solid var(--border);border-radius:14px;padding:15px;font-size:16px;outline:none;transition:0.3s}
.inp:focus{border-color:var(--blue);background:white}

.btn-main{width:100%;padding:18px;border-radius:18px;font-size:16px;font-weight:700;cursor:pointer;border:none;transition:0.3s}
.btn-blue{background:var(--blue);color:#fff;box-shadow:0 4px 12px rgba(59,130,246,0.3)}
.btn-blue:active{transform:scale(0.96)}
.btn-outline{background:transparent;color:var(--blue);border:2px solid var(--blue)}
.wiz-footer{position:fixed;bottom:0;left:0;right:0;background:rgba(255,255,255,0.8);backdrop-filter:blur(15px);border-top:1px solid var(--border);padding:20px 25px 30px;z-index:100}

.app-card{background:white;border-radius:20px;padding:20px;display:flex;align-items:center;gap:15px;box-shadow:var(--shadow);border:1px solid var(--border);margin-bottom:15px}
.app-icon-ui{width:50px;height:50px;background:var(--blue-l);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px}

@keyframes rotate { from {transform:rotate(0deg)} to {transform:rotate(360deg)} }
.loader{width:45px;height:45px;border:4px solid var(--blue-l);border-top-color:var(--blue);border-radius:50%;animation:rotate 1s linear infinite;margin:0 auto 20px}
</style>
</head>
<body>

<div class="view active" id="v-dashboard">
    <nav class="navbar"><div class="logo">WebForge<span>Pro</span></div><button onclick="goto('v-settings')" style="background:none;border:none;font-size:22px">⚙️</button></nav>
    <div style="padding:25px 20px">
        <h1 style="font-size:28px; font-weight:800; margin-bottom:20px">Mis Apps</h1>
        <div id="apps-list"></div>
    </div>
    <button onclick="startWizard()" style="position:fixed;bottom:30px;right:25px;width:65px;height:65px;border-radius:22px;background:var(--blue);color:white;border:none;font-size:35px;box-shadow:0 10px 20px rgba(59,130,246,0.4)">+</button>
</div>

<div class="view" id="v-wizard">
    <nav class="navbar"><button onclick="goto('v-dashboard')" style="background:none;border:none;font-size:20px">✕</button><div class="logo">Constructor</div><div style="width:35px"></div></nav>
    <div class="wiz-dots" id="wiz-dots"></div>
    <div class="wiz-body" id="wiz-body"></div>
    <div class="wiz-footer">
        <div style="display:flex; gap:12px">
            <button class="btn-main btn-outline" id="btn-wiz-prev" onclick="wizPrev()" style="display:none;flex:1">Atrás</button>
            <button class="btn-main btn-blue" id="btn-wiz-next" onclick="wizNext()" style="flex:2">Continuar</button>
        </div>
    </div>
</div>

<div class="view" id="v-proc">
    <nav class="navbar"><div class="logo">WebForge<span>Engine</span></div></nav>
    <div style="padding:60px 30px; text-align:center">
        <div class="loader" id="p-loader"></div>
        <h2 id="p-title" style="font-size:22px; font-weight:800; margin-bottom:10px">Compilando...</h2>
        <p id="p-desc" style="color:var(--muted); margin-bottom:30px">Esto puede tardar unos 2-3 minutos.</p>
        
        <div style="text-align:left; background:white; padding:25px; border-radius:22px; border:1px solid var(--border); box-shadow:var(--shadow)">
            <div id="l1" style="margin-bottom:12px; color:var(--muted)">○ Sincronizando código</div>
            <div id="l2" style="margin-bottom:12px; color:var(--muted)">○ Ejecutando Gradle Build</div>
            <div id="l3" style="color:var(--muted)">○ Generando APK firmado</div>
        </div>
        <button id="btn-install" class="btn-main btn-blue" style="display:none; margin-top:30px; background:var(--green)" onclick="install()">📥 DESCARGAR APK</button>
    </div>
</div>

<div class="view" id="v-settings">
    <nav class="navbar"><button onclick="goto('v-dashboard')" style="background:none;border:none;font-size:20px">←</button><div class="logo">Configuración</div><div style="width:35px"></div></nav>
    <div style="padding:30px 20px">
        <div class="field"><label>GitHub Personal Token</label><input class="inp" type="password" id="cfg-token" placeholder="ghp_xxxx"></div>
        <button class="btn-main btn-blue" onclick="saveSettings()">Guardar Ajustes</button>
    </div>
</div>

<script>
const USER = "javierc232", REPO = "Generador-apk";
let apps = JSON.parse(localStorage.getItem('wf_projects') || '[]');
let step = 1, apkFinalUrl = "", poll = null;
let appData = { type:'file', name:'', pkg:'', file:'', icon:'', iconUrl:'' };

function goto(id) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById(id).classList.add('active');
}

function startWizard() { step=1; renderStep(); goto('v-wizard'); }

function renderStep() {
    const body = document.getElementById('wiz-body');
    const dots = document.getElementById('wiz-dots');
    dots.innerHTML = Array.from({length:9}, (_,i) => `<div class="wiz-dot ${i+1===step?'on':''}"></div>`).join('');
    document.getElementById('btn-wiz-prev').style.display = step===1 ? 'none' : 'block';
    document.getElementById('btn-wiz-next').innerText = step===9 ? 'COMPILAR AHORA' : 'CONTINUAR';

    if(step===1) {
        body.innerHTML = `<div class="wiz-card"><h2>¿Qué compilamos?</h2><p>Sube un archivo .zip, .html o introduce una URL.</p>
        <button class="btn-main btn-outline" style="border-style:dashed; margin-bottom:15px" onclick="document.getElementById('f-in').click()">📁 ${appData.name || 'Seleccionar Archivo'}</button>
        <input type="file" id="f-in" hidden onchange="handleFile(this)">
        <input class="inp" id="w-url" placeholder="O pega una URL: https://..." oninput="appData.type='url'; appData.file=this.value"></div>`;
    } else if(step===2) {
        body.innerHTML = `<div class="wiz-card"><h2>Identidad</h2><p>Define cómo se verá en el teléfono.</p>
        <div class="field"><label>Nombre de App</label><input class="inp" id="n-in" value="${appData.name}" oninput="autoPkg(this.value)"></div>
        <div class="field"><label>Package ID</label><input class="inp" id="p-in" value="${appData.pkg}" oninput="appData.pkg=this.value"></div></div>`;
    } else if(step===3) {
        body.innerHTML = `<div class="wiz-card"><h2>Icono Pro</h2><p>Sube una imagen y la ajustaremos.</p>
        <div onclick="document.getElementById('i-in').click()" style="width:100px; height:100px; margin:0 auto; border:3px dashed var(--blue); border-radius:25px; display:flex; align-items:center; justify-content:center; cursor:pointer; overflow:hidden">
            ${appData.iconUrl ? `<img src="${appData.iconUrl}" style="width:100%">` : '<span style="font-size:40px; color:var(--blue)">+</span>'}
        </div><input type="file" id="i-in" hidden accept="image/*" onchange="handleIcon(this)"></div>`;
    } else {
        body.innerHTML = `<div class="wiz-card"><h2>Paso ${step}</h2><p>Configurando optimización de código y librerías externas.</p></div>`;
    }
}

function autoPkg(v) {
    appData.name = v;
    appData.pkg = `com.webforge.${v.toLowerCase().replace(/[^a-z0-9]/g,'') || 'app'}`;
    if(document.getElementById('p-in')) document.getElementById('p-in').value = appData.pkg;
}

function handleFile(i) {
    const f = i.files[0]; appData.name = f.name;
    const r = new FileReader(); r.onload = (e) => { appData.file = e.target.result.split(',')[1]; appData.type = 'file'; renderStep(); };
    r.readAsDataURL(f);
}

function handleIcon(i) {
    const f = i.files[0]; const r = new FileReader();
    r.onload = (e) => {
        const img = new Image(); img.onload = () => {
            const canvas = document.createElement('canvas'); canvas.width = 192; canvas.height = 192;
            canvas.getContext('2d').drawImage(img,0,0,192,192);
            appData.icon = canvas.toDataURL('image/png').split(',')[1];
            appData.iconUrl = canvas.toDataURL('image/png'); renderStep();
        }; img.src = e.target.result;
    }; r.readAsDataURL(f);
}

function wizNext() { if(step<9) { step++; renderStep(); } else { build(); } }
function wizPrev() { step--; renderStep(); }

async function upload(path, content, token) {
    const url = `https://api.github.com/repos/${USER}/${REPO}/contents/${path}`;
    let sha = null;
    const res = await fetch(url, { headers: { "Authorization": `token ${token}` } });
    if(res.ok) { const d = await res.json(); sha = d.sha; }
    return fetch(url, {
        method: "PUT",
        headers: { "Authorization": `token ${token}`, "Content-Type": "application/json" },
        body: JSON.stringify({ message: "Sync", content: content, sha: sha })
    });
}

async function build() {
    const tk = localStorage.getItem('wf_token'); if(!tk) return goto('v-settings');
    goto('v-proc');
    try {
        await upload("input_assets/app_data.bin", appData.file, tk);
        if(appData.icon) await upload("input_assets/icon.png", appData.icon, tk);
        const config = { name: appData.name, package: appData.pkg, source: appData.type };
        await upload("input_assets/config.json", btoa(JSON.stringify(config)), tk);
        document.getElementById('l1').innerHTML = "✅ Sincronizado";

        await fetch(`https://api.github.com/repos/${USER}/${REPO}/dispatches`, {
            method: "POST",
            headers: { "Authorization": `token ${tk}`, "Accept": "application/vnd.github.v3+json" },
            body: JSON.stringify({ event_type: "build_app", client_payload: config })
        });
        document.getElementById('l2').innerHTML = "⏳ Gradle en ejecución...";
        startPolling(tk);
    } catch(e) { alert(e); }
}

function startPolling(tk) {
    const start = Date.now();
    poll = setInterval(async () => {
        const res = await fetch(`https://api.github.com/repos/${USER}/${REPO}/releases/latest`, { headers: { "Authorization": `token ${tk}` }, cache:'no-store' });
        if(res.ok) {
            const d = await res.json();
            const apk = d.assets.find(a => a.name.endsWith('.apk'));
            if(apk && new Date(d.created_at).getTime() > start) {
                clearInterval(poll);
                apkFinalUrl = apk.browser_download_url;
                document.getElementById('l2').innerHTML = "✅ Build Finalizada";
                document.getElementById('l3').innerHTML = "✅ APK Firmado";
                document.getElementById('p-loader').style.display = "none";
                document.getElementById('btn-install').style.display = "block";
                apps.unshift({name: appData.name, pkg: appData.pkg, date: new Date().toLocaleDateString()});
                localStorage.setItem('wf_projects', JSON.stringify(apps));
                renderApps();
            }
        }
    }, 12000);
}

function install() { window.location.href = apkFinalUrl; }
function saveSettings() { localStorage.setItem('wf_token', document.getElementById('cfg-token').value); goto('v-dashboard'); }
function renderApps() {
    document.getElementById('apps-list').innerHTML = apps.map(a => `
        <div class="app-card">
            <div class="app-icon-ui">📱</div>
            <div style="flex:1"><b>${a.name}</b><br><small style="color:var(--muted)">${a.pkg}</small></div>
            <div style="font-size:12px; color:var(--muted)">${a.date}</div>
        </div>
    `).join('') || '<p style="text-align:center; padding:40px; color:var(--muted)">No hay proyectos creados.</p>';
}

window.onload = () => {
    const t = localStorage.getItem('wf_token'); if(t) document.getElementById('cfg-token').value = t;
    renderApps();
};
</script>
</body>
</html>
