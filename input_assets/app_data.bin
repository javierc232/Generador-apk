// ═════════════════════════════════════════════════════════════════════════════
//  MODELO
// ═════════════════════════════════════════════════════════════════════════════
class ProjectFile {
    public String localPath, remotePath, fileName, type;

    public ProjectFile(String local, String name) {
        this.localPath  = local;
        this.fileName   = name;
        this.type       = detect(name);
        this.remotePath = remote(name, this.type);
    }

    private String detect(String n) {
        n = n.toLowerCase();
        if (n.endsWith(".java"))  return "java";
        if (n.endsWith(".kt"))    return "kotlin";
        if (n.endsWith(".xml"))   return "xml";
        if (n.endsWith(".gradle") || n.endsWith(".kts")) return "gradle";
        if (n.endsWith(".zip"))   return "zip";
        if (n.matches(".*\\.(png|jpg|jpeg|webp|svg|ico)")) return "image";
        return "other";
    }

    private String remote(String name, String t) {
        switch (t) {
            case "java": case "kotlin": return "app/src/main/java/" + name;
            case "xml":  return name.equals("AndroidManifest.xml")
                            ? "app/src/main/" + name
                            : "app/src/main/res/layout/" + name;
            case "gradle": return name;
            case "image":  return "app/src/main/res/drawable/" + name;
            case "zip":    return "project_source.zip";
            default:       return "extras/" + name;
        }
    }

    public String emoji() {
        switch (type) {
            case "java":   return "☕";
            case "kotlin": return "🟣";
            case "xml":    return "📄";
            case "gradle": return "🔧";
            case "image":  return "🖼";
            case "zip":    return "📦";
            default:       return "📎";
        }
    }
}

