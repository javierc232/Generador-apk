package com.convertx.pro;

import android.Manifest;
import android.app.Activity;
import android.content.Context;
import android.content.Intent;
import android.content.pm.PackageManager;
import android.graphics.Bitmap;
import android.graphics.BitmapFactory;
import android.net.Uri;
import android.os.Build;
import android.os.Bundle;
import android.os.Environment;
import android.provider.MediaStore;
import android.text.Editable;
import android.text.TextWatcher;
import android.view.MotionEvent;
import android.view.View;
import android.view.ViewGroup;
import android.widget.Button;
import android.widget.EditText;
import android.widget.FrameLayout;
import android.widget.ImageButton;
import android.widget.ImageView;
import android.widget.LinearLayout;
import android.widget.ScrollView;
import android.widget.TextView;
import android.widget.Toast;

import androidx.appcompat.app.AppCompatActivity;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;
import androidx.core.content.FileProvider;

import com.itextpdf.io.image.ImageData;
import com.itextpdf.io.image.ImageDataFactory;
import com.itextpdf.kernel.pdf.PdfDocument;
import com.itextpdf.kernel.pdf.PdfWriter;
import com.itextpdf.layout.Document;
import com.itextpdf.layout.element.Image;
import com.itextpdf.layout.element.Paragraph;

import java.io.File;
import java.io.FileOutputStream;
import java.io.IOException;
import java.text.SimpleDateFormat;
import java.util.ArrayList;
import java.util.Date;
import java.util.Locale;

public class MainActivity extends AppCompatActivity {
    // Constantes
    private static final int REQUEST_CAMERA = 1;
    private static final int REQUEST_GALLERY = 2;
    private static final int REQUEST_PERMISSION_CAMERA = 100;
    private static final int REQUEST_PERMISSION_STORAGE = 101;

    // UI Elements
    private EditText titleInput;
    private EditText contentInput;
    private TextView wordCount;
    private TextView charCount;
    private LinearLayout imageContainer;
    private LinearLayout tabContainer;
    private FrameLayout screenContainer;
    private ScrollView editorScreen;
    private LinearLayout imagenScreen;
    private LinearLayout exportScreen;
    private Button btnCamera;
    private Button btnGallery;
    private Button btnExportPDF;
    private Button btnExportDOCX;
    private Button btnExportTXT;
    private Button btnBold;
    private Button btnItalic;
    private Button btnUnderline;
    private Button btnNew;
    private Button btnFormatPDF;
    private Button btnFormatDOCX;
    private Button btnFormatTXT;
    private Button btnDoExport;
    private TextView exportStatus;

    // Variables
    private String currentPhotoPath;
    private Bitmap currentImageBitmap;
    private ArrayList<Bitmap> documentImages = new ArrayList<>();
    private String selectedFormat = "PDF";
    private int currentScreen = 0;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        initializeViews();
        setupListeners();
        checkPermissions();
        loadSavedDocument();
    }

    private void initializeViews() {
        // Editor Screen
        titleInput = findViewById(R.id.titleInput);
        contentInput = findViewById(R.id.contentInput);
        wordCount = findViewById(R.id.wordCount);
        charCount = findViewById(R.id.charCount);
        imageContainer = findViewById(R.id.imageContainer);

        // Toolbar
        btnBold = findViewById(R.id.btnBold);
        btnItalic = findViewById(R.id.btnItalic);
        btnUnderline = findViewById(R.id.btnUnderline);

        // Buttons
        btnCamera = findViewById(R.id.btnCamera);
        btnGallery = findViewById(R.id.btnGallery);
        btnNew = findViewById(R.id.btnNew);

        // Tabs
        tabContainer = findViewById(R.id.tabContainer);

        // Screens
        screenContainer = findViewById(R.id.screenContainer);
        editorScreen = findViewById(R.id.editorScreen);
        imagenScreen = findViewById(R.id.imagenScreen);
        exportScreen = findViewById(R.id.exportScreen);

        // Export buttons
        btnFormatPDF = findViewById(R.id.btnFormatPDF);
        btnFormatDOCX = findViewById(R.id.btnFormatDOCX);
        btnFormatTXT = findViewById(R.id.btnFormatTXT);
        btnDoExport = findViewById(R.id.btnDoExport);
        exportStatus = findViewById(R.id.exportStatus);
        btnExportPDF = findViewById(R.id.btnExportPDF);
        btnExportDOCX = findViewById(R.id.btnExportDOCX);
        btnExportTXT = findViewById(R.id.btnExportTXT);
    }

    private void setupListeners() {
        // Text listeners
        contentInput.addTextChangedListener(new TextWatcher() {
            @Override
            public void beforeTextChanged(CharSequence s, int start, int count, int after) {}

            @Override
            public void onTextChanged(CharSequence s, int start, int before, int count) {
                updateStats();
            }

            @Override
            public void afterTextChanged(Editable s) {}
        });

        // Format buttons
        btnBold.setOnClickListener(v -> {
            applyFormat("bold");
            Toast.makeText(MainActivity.this, "Negrita aplicada", Toast.LENGTH_SHORT).show();
        });

        btnItalic.setOnClickListener(v -> {
            applyFormat("italic");
            Toast.makeText(MainActivity.this, "Cursiva aplicada", Toast.LENGTH_SHORT).show();
        });

        btnUnderline.setOnClickListener(v -> {
            applyFormat("underline");
            Toast.makeText(MainActivity.this, "Subrayado aplicado", Toast.LENGTH_SHORT).show();
        });

        // Image buttons
        btnCamera.setOnClickListener(v -> openCamera());
        btnGallery.setOnClickListener(v -> openGallery());

        // Tab buttons
        setupTabs();

        // Export format selection
        btnFormatPDF.setOnClickListener(v -> selectFormat("PDF", btnFormatPDF));
        btnFormatDOCX.setOnClickListener(v -> selectFormat("DOCX", btnFormatDOCX));
        btnFormatTXT.setOnClickListener(v -> selectFormat("TXT", btnFormatTXT));

        // Export button
        btnDoExport.setOnClickListener(v -> exportDocument());

        // New document
        btnNew.setOnClickListener(v -> newDocument());

        // Quick export
        btnExportPDF.setOnClickListener(v -> quickExport("PDF"));
        btnExportDOCX.setOnClickListener(v -> quickExport("DOCX"));
        btnExportTXT.setOnClickListener(v -> quickExport("TXT"));
    }

    private void setupTabs() {
        LinearLayout tab0 = findViewById(R.id.tab0);
        LinearLayout tab1 = findViewById(R.id.tab1);
        LinearLayout tab2 = findViewById(R.id.tab2);

        tab0.setOnClickListener(v -> switchScreen(0));
        tab1.setOnClickListener(v -> switchScreen(1));
        tab2.setOnClickListener(v -> switchScreen(2));
    }

    private void switchScreen(int screen) {
        currentScreen = screen;
        editorScreen.setVisibility(screen == 0 ? View.VISIBLE : View.GONE);
        imagenScreen.setVisibility(screen == 1 ? View.VISIBLE : View.GONE);
        exportScreen.setVisibility(screen == 2 ? View.VISIBLE : View.GONE);

        // Update tab colors
        updateTabColors();
    }

    private void updateTabColors() {
        LinearLayout tab0 = findViewById(R.id.tab0);
        LinearLayout tab1 = findViewById(R.id.tab1);
        LinearLayout tab2 = findViewById(R.id.tab2);

        int activeColor = getResources().getColor(R.color.purple_500);
        int inactiveColor = getResources().getColor(R.color.dark_text_secondary);

        tab0.setBackgroundColor(currentScreen == 0 ? activeColor : inactiveColor);
        tab1.setBackgroundColor(currentScreen == 1 ? activeColor : inactiveColor);
        tab2.setBackgroundColor(currentScreen == 2 ? activeColor : inactiveColor);
    }

    private void updateStats() {
        String text = contentInput.getText().toString();
        int words = text.isEmpty() ? 0 : text.trim().split("\\s+").length;
        int chars = text.length();
        wordCount.setText(String.valueOf(words));
        charCount.setText(String.valueOf(chars));
        saveDocument();
    }

    private void checkPermissions() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.CAMERA)
                    != PackageManager.PERMISSION_GRANTED) {
                ActivityCompat.requestPermissions(this,
                        new String[]{Manifest.permission.CAMERA},
                        REQUEST_PERMISSION_CAMERA);
            }
            if (ContextCompat.checkSelfPermission(this, Manifest.permission.WRITE_EXTERNAL_STORAGE)
                    != PackageManager.PERMISSION_GRANTED) {
                ActivityCompat.requestPermissions(this,
                        new String[]{Manifest.permission.WRITE_EXTERNAL_STORAGE},
                        REQUEST_PERMISSION_STORAGE);
            }
        }
    }

    private void openCamera() {
        Intent intent = new Intent(MediaStore.ACTION_IMAGE_CAPTURE);
        if (intent.resolveActivity(getPackageManager()) != null) {
            File photoFile = null;
            try {
                photoFile = createImageFile();
            } catch (IOException e) {
                Toast.makeText(this, "Error: " + e.getMessage(), Toast.LENGTH_SHORT).show();
            }
            if (photoFile != null) {
                Uri photoUri = FileProvider.getUriForFile(this,
                        "com.convertx.pro.fileprovider", photoFile);
                intent.putExtra(MediaStore.EXTRA_OUTPUT, photoUri);
                startActivityForResult(intent, REQUEST_CAMERA);
            }
        }
    }

    private void openGallery() {
        Intent intent = new Intent(Intent.ACTION_PICK, MediaStore.Images.Media.EXTERNAL_CONTENT_URI);
        startActivityForResult(intent, REQUEST_GALLERY);
    }

    private File createImageFile() throws IOException {
        String timeStamp = new SimpleDateFormat("yyyyMMdd_HHmmss", Locale.getDefault()).format(new Date());
        String imageFileName = "JPEG_" + timeStamp + "_";
        File storageDir = getExternalFilesDir(Environment.DIRECTORY_PICTURES);
        File image = File.createTempFile(imageFileName, ".jpg", storageDir);
        currentPhotoPath = image.getAbsolutePath();
        return image;
    }

    @Override
    protected void onActivityResult(int requestCode, int resultCode, Intent data) {
        super.onActivityResult(requestCode, resultCode, data);

        if (resultCode == Activity.RESULT_OK) {
            if (requestCode == REQUEST_CAMERA) {
                try {
                    currentImageBitmap = BitmapFactory.decodeFile(currentPhotoPath);
                    displayImage(currentImageBitmap);
                } catch (Exception e) {
                    Toast.makeText(this, "Error: " + e.getMessage(), Toast.LENGTH_SHORT).show();
                }
            } else if (requestCode == REQUEST_GALLERY && data != null) {
                Uri selectedImage = data.getData();
                try {
                    currentImageBitmap = MediaStore.Images.Media.getBitmap(this.getContentResolver(), selectedImage);
                    displayImage(currentImageBitmap);
                } catch (IOException e) {
                    Toast.makeText(this, "Error: " + e.getMessage(), Toast.LENGTH_SHORT).show();
                }
            }
        }
    }

    private void displayImage(Bitmap bitmap) {
        if (bitmap == null) return;

        documentImages.add(bitmap);

        ImageView imgView = new ImageView(this);
        imgView.setImageBitmap(bitmap);
        imgView.setScaleType(ImageView.ScaleType.CENTER_INSIDE);

        LinearLayout.LayoutParams params = new LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, 300);
        params.setMargins(0, 10, 0, 10);
        imgView.setLayoutParams(params);

        imgView.setOnClickListener(v -> resizeImage(imgView));
        imageContainer.addView(imgView);

        Toast.makeText(this, "Imagen insertada. Toca para redimensionar", Toast.LENGTH_SHORT).show();
    }

    private void resizeImage(ImageView imgView) {
        ViewGroup.LayoutParams params = imgView.getLayoutParams();
        if (params.height == 300) {
            params.height = 500;
        } else if (params.height == 500) {
            params.height = 150;
        } else {
            params.height = 300;
        }
        imgView.setLayoutParams(params);
        Toast.makeText(this, "Imagen redimensionada", Toast.LENGTH_SHORT).show();
    }

    private void applyFormat(String format) {
        String selected = contentInput.getText().toString();
        int start = contentInput.getSelectionStart();
        int end = contentInput.getSelectionEnd();

        if (start == end) {
            Toast.makeText(this, "Selecciona texto para aplicar formato", Toast.LENGTH_SHORT).show();
            return;
        }

        String selectedText = selected.substring(start, end);
        String formatted;

        switch (format) {
            case "bold":
                formatted = "**" + selectedText + "**";
                break;
            case "italic":
                formatted = "*" + selectedText + "*";
                break;
            case "underline":
                formatted = "__" + selectedText + "__";
                break;
            default:
                formatted = selectedText;
        }

        contentInput.getText().replace(start, end, formatted);
    }

    private void newDocument() {
        if (!contentInput.getText().toString().isEmpty()) {
            if (!showConfirmDialog("¿Descartar cambios?")) {
                return;
            }
        }
        titleInput.setText("Mi Documento");
        contentInput.setText("");
        imageContainer.removeAllViews();
        documentImages.clear();
        updateStats();
        Toast.makeText(this, "Nuevo documento creado", Toast.LENGTH_SHORT).show();
    }

    private void selectFormat(String format, Button btn) {
        selectedFormat = format;

        // Update button colors
        btnFormatPDF.setBackgroundColor(getResources().getColor(
                format.equals("PDF") ? R.color.red_500 : R.color.dark_surface));
        btnFormatDOCX.setBackgroundColor(getResources().getColor(
                format.equals("DOCX") ? R.color.purple_500 : R.color.dark_surface));
        btnFormatTXT.setBackgroundColor(getResources().getColor(
                format.equals("TXT") ? R.color.teal_200 : R.color.dark_surface));

        Toast.makeText(this, "Formato seleccionado: " + format, Toast.LENGTH_SHORT).show();
    }

    private void exportDocument() {
        try {
            String title = titleInput.getText().toString().isEmpty() ? "Documento" : titleInput.getText().toString();
            String content = contentInput.getText().toString();

            exportStatus.setText("Exportando...");

            switch (selectedFormat) {
                case "PDF":
                    exportPDF(title, content);
                    break;
                case "DOCX":
                    exportDOCX(title, content);
                    break;
                case "TXT":
                    exportTXT(title, content);
                    break;
            }

            exportStatus.setText("✅ Exportado correctamente");
        } catch (Exception e) {
            exportStatus.setText("❌ Error: " + e.getMessage());
        }
    }

    private void quickExport(String format) {
        try {
            String title = titleInput.getText().toString().isEmpty() ? "Documento" : titleInput.getText().toString();
            String content = contentInput.getText().toString();

            switch (format) {
                case "PDF":
                    exportPDF(title, content);
                    break;
                case "DOCX":
                    exportDOCX(title, content);
                    break;
                case "TXT":
                    exportTXT(title, content);
                    break;
            }

            Toast.makeText(this, format + " descargado", Toast.LENGTH_SHORT).show();
        } catch (Exception e) {
            Toast.makeText(this, "Error: " + e.getMessage(), Toast.LENGTH_SHORT).show();
        }
    }

    private void exportPDF(String title, String content) throws IOException {
        File pdfFile = new File(getExternalFilesDir(null), title + ".pdf");
        PdfWriter writer = new PdfWriter(pdfFile);
        PdfDocument pdfDoc = new PdfDocument(writer);
        Document document = new Document(pdfDoc);

        document.add(new Paragraph(title).setBold().setFontSize(18));
        document.add(new Paragraph(content).setFontSize(12));

        // Agregar imágenes
        for (Bitmap img : documentImages) {
            try {
                File imgFile = new File(getCacheDir(), "temp_" + System.currentTimeMillis() + ".png");
                FileOutputStream fos = new FileOutputStream(imgFile);
                img.compress(Bitmap.CompressFormat.PNG, 100, fos);
                fos.close();

                ImageData imageData = ImageDataFactory.create(imgFile.getAbsolutePath());
                Image image = new Image(imageData);
                image.setMaxWidth(500);
                document.add(image);
            } catch (Exception e) {
                e.printStackTrace();
            }
        }

        document.close();
        Toast.makeText(this, "PDF guardado: " + pdfFile.getAbsolutePath(), Toast.LENGTH_LONG).show();
    }

    private void exportDOCX(String title, String content) throws IOException {
        File docFile = new File(getExternalFilesDir(null), title + ".docx");
        FileOutputStream fos = new FileOutputStream(docFile);
        fos.write((title + "\n\n" + content).getBytes());
        fos.close();
        Toast.makeText(this, "DOCX guardado: " + docFile.getAbsolutePath(), Toast.LENGTH_LONG).show();
    }

    private void exportTXT(String title, String content) throws IOException {
        File txtFile = new File(getExternalFilesDir(null), title + ".txt");
        FileOutputStream fos = new FileOutputStream(txtFile);
        fos.write(content.getBytes());
        fos.close();
        Toast.makeText(this, "TXT guardado: " + txtFile.getAbsolutePath(), Toast.LENGTH_LONG).show();
    }

    private void saveDocument() {
        // Implementar con SharedPreferences
        android.content.SharedPreferences pref = getSharedPreferences("convertx", MODE_PRIVATE);
        android.content.SharedPreferences.Editor editor = pref.edit();
        editor.putString("title", titleInput.getText().toString());
        editor.putString("content", contentInput.getText().toString());
        editor.apply();
    }

    private void loadSavedDocument() {
        android.content.SharedPreferences pref = getSharedPreferences("convertx", MODE_PRIVATE);
        String title = pref.getString("title", "Mi Documento");
        String content = pref.getString("content", "");
        titleInput.setText(title);
        contentInput.setText(content);
    }

    private boolean showConfirmDialog(String message) {
        android.app.AlertDialog.Builder builder = new android.app.AlertDialog.Builder(this);
        builder.setMessage(message)
                .setPositiveButton("Sí", (dialog, id) -> {})
                .setNegativeButton("No", (dialog, id) -> {});
        android.app.AlertDialog dialog = builder.create();
        dialog.show();
        return true;
    }
}
