package com.webforge.calculadora;

import android.app.Activity;
import android.os.Bundle;
import android.view.Gravity;
import android.view.View;
import android.widget.Button;
import android.widget.GridLayout;
import android.widget.LinearLayout;
import android.widget.TextView;
import android.graphics.Color;
import android.graphics.Typeface;

public class Calculadora extends Activity {

    TextView pantalla;
    String operacion = "";
    double num1 = 0;
    String operadorActual = "";
    boolean nuevaOperacion = false;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        LinearLayout root = new LinearLayout(this);
        root.setOrientation(LinearLayout.VERTICAL);
        root.setBackgroundColor(Color.RED);
        root.setPadding(20, 40, 20, 20);

        // Pantalla
        pantalla = new TextView(this);
        pantalla.setText("0");
        pantalla.setTextSize(48);
        pantalla.setTextColor(Color.GREEN);
        pantalla.setBackgroundColor(Color.BLACK);
        pantalla.setGravity(Gravity.END | Gravity.CENTER_VERTICAL);
        pantalla.setPadding(20, 20, 20, 20);
        pantalla.setTypeface(Typeface.MONOSPACE);
        LinearLayout.LayoutParams pantallaParams = new LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 180);
        pantallaParams.setMargins(0, 0, 0, 20);
        root.addView(pantalla, pantallaParams);

        // Grid de botones
        GridLayout grid = new GridLayout(this);
        grid.setColumnCount(4);
        grid.setRowCount(5);

        String[] botones = {
            "C", "+/-", "%", "÷",
            "7", "8", "9", "×",
            "4", "5", "6", "-",
            "1", "2", "3", "+",
            "0", ".", "⌫", "="
        };

        for (String texto : botones) {
            Button btn = new Button(this);
            btn.setText(texto);
            btn.setTextSize(22);
            btn.setTextColor(Color.WHITE);
            btn.setTypeface(null, Typeface.BOLD);
            btn.setBackgroundColor(Color.BLACK);

            if (texto.equals("=")) {
                btn.setBackgroundColor(Color.parseColor("#FF6600"));
            } else if (texto.equals("C")) {
                btn.setBackgroundColor(Color.parseColor("#CC0000"));
            }

            GridLayout.LayoutParams params = new GridLayout.LayoutParams();
            params.width = 0;
            params.height = 160;
            params.columnSpec = GridLayout.spec(GridLayout.UNDEFINED, 1, 1f);
            params.setMargins(5, 5, 5, 5);
            btn.setLayoutParams(params);

            btn.setOnClickListener(v -> onBoton(texto));
            grid.addView(btn);
        }

        root.addView(grid);
        setContentView(root);
    }

    void onBoton(String texto) {
        switch (texto) {
            case "C":
                pantalla.setText("0");
                operacion = "";
                num1 = 0;
                operadorActual = "";
                nuevaOperacion = false;
                break;
            case "⌫":
                String actual = pantalla.getText().toString();
                if (actual.length() > 1) {
                    pantalla.setText(actual.substring(0, actual.length() - 1));
                } else {
                    pantalla.setText("0");
                }
                break;
            case "+": case "-": case "×": case "÷": case "%":
                num1 = Double.parseDouble(pantalla.getText().toString());
                operadorActual = texto;
                nuevaOperacion = true;
                break;
            case "+/-":
                double val = Double.parseDouble(pantalla.getText().toString());
                pantalla.setText(formatear(-val));
                break;
            case "=":
                if (!operadorActual.isEmpty()) {
                    double num2 = Double.parseDouble(pantalla.getText().toString());
                    double resultado = 0;
                    switch (operadorActual) {
                        case "+": resultado = num1 + num2; break;
                        case "-": resultado = num1 - num2; break;
                        case "×": resultado = num1 * num2; break;
                        case "÷": resultado = num2 != 0 ? num1 / num2 : 0; break;
                        case "%": resultado = num1 % num2; break;
                    }
                    pantalla.setText(formatear(resultado));
                    operadorActual = "";
                    nuevaOperacion = true;
                }
                break;
            case ".":
                if (!pantalla.getText().toString().contains(".")) {
                    pantalla.setText(pantalla.getText() + ".");
                }
                break;
            default:
                if (nuevaOperacion || pantalla.getText().toString().equals("0")) {
                    pantalla.setText(texto);
                    nuevaOperacion = false;
                } else {
                    pantalla.setText(pantalla.getText() + texto);
                }
        }
    }

    String formatear(double valor) {
        if (valor == (long) valor) {
            return String.valueOf((long) valor);
        }
        return String.valueOf(valor);
    }
}