// ─────────────────────────────────────────────────────────────────────────────
//  MODELO DE DATOS (Soporta URL, HTML, Java, C++, ZIP)
// ─────────────────────────────────────────────────────────────────────────────
class AppConfig {
    public String id;
    public String appName;
    public String packageName;
    public int version = 1;
    public String websiteUrl;
    public String htmlContent;
    public String javaCustomCode;
    public String cppCustomCode;
    public String zipFilePath; // Ruta al archivo zip seleccionado
    public String inputType = "URL"; // URL, HTML, JAVA, CPP, ZIP
    public String themeColor = "#3B82F6";
    public String progressBarStyle = "circular";
    public boolean bottomNavEnabled;
    public String userAgent;
    public String iconPath;
    public String appPurpose;
    
    public AppConfig() {
        this.id = UUID.randomUUID().toString();
    }
}

// ─────────────────────────────────────────────────────────────────────────────
//  PANTALLA PRINCIPAL: LISTADO Y DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────
public class MainActivity extends AppCompatActivity {
    private LinearLayout listContainer;
    private SharedPreferences prefs;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        prefs = getSharedPreferences("WebForgePrefs", MODE_PRIVATE);

        // UI principal
        FrameLayout root = new FrameLayout(this);
        root.setBackgroundColor(Color.parseColor("#F8FAFC"));

        LinearLayout content = new LinearLayout(this);
        content.setOrientation(LinearLayout.VERTICAL);
        content.setPadding(dp(20), dp(20), dp(20), dp(100));
        
        TextView title = new TextView(this);
        title.setText("Mis Aplicaciones");
        title.setTextSize(26);
        title.setTypeface(null, android.graphics.Typeface.BOLD);
        title.setTextColor(Color.parseColor("#1E293B"));
        content.addView(title);

        listContainer = new LinearLayout(this);
        listContainer.setOrientation(LinearLayout.VERTICAL);
        content.addView(listContainer);

        ScrollView sv = new ScrollView(this);
        sv.addView(content);
        root.addView(sv);

        // Botón FLOTANTE para nueva APP
        Button fab = new Button(this);
        fab.setText("+ Crear Nueva App");
        fab.setTextColor(Color.WHITE);
        fab.setAllCaps(false);
        GradientDrawable fabBg = new GradientDrawable();
        fabBg.setColor(Color.parseColor("#3B82F6"));
        fabBg.setCornerRadius(dp(30));
        fab.setBackground(fabBg);
        
        FrameLayout.LayoutParams lp = new FrameLayout.LayoutParams(dp(200), dp(60));
        lp.gravity = Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL;
        lp.bottomMargin = dp(30);
        fab.setLayoutParams(lp);
        fab.setOnClickListener(v -> checkPermissionsAndStart());
        root.addView(fab);

        setContentView(root);
        refreshList();
    }

    private void refreshList() {
        listContainer.removeAllViews();
        // Aquí cargarías las apps de SharedPreferences (similar al código anterior)
    }

    private void checkPermissionsAndStart() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
            if (!Environment.isExternalStorageManager()) {
                Intent i = new Intent(Settings.ACTION_MANAGE_ALL_FILES_ACCESS_PERMISSION);
                startActivity(i);
                return;
            }
        }
        startActivity(new Intent(this, WizardActivity.class));
    }

    private int dp(int value) {
        return (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, value, getResources().getDisplayMetrics());
    }
}

// ─────────────────────────────────────────────────────────────────────────────
//  WIZARD MULTI-FORMATO (El "Preguntador")
// ─────────────────────────────────────────────────────────────────────────────
class WizardActivity extends AppCompatActivity {
    private int step = 1;
    private AppConfig config = new AppConfig();

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        mostrarPaso();
    }

    private void mostrarPaso() {
        LinearLayout layout = new LinearLayout(this);
        layout.setOrientation(LinearLayout.VERTICAL);
        layout.setPadding(30, 30, 30, 30);
        layout.setGravity(Gravity.CENTER);

        switch (step) {
            case 1:
                renderInputSelection(layout);
                break;
            case 2:
                renderAppDetails(layout);
                break;
            // ... pasos adicionales ...
        }
        setContentView(layout);
    }

    private void renderInputSelection(LinearLayout layout) {
        TextView q = new TextView(this);
        q.setText("¿Qué usaremos como base?");
        q.setTextSize(20);
        layout.addView(q);

        String[] opciones = {"Sitio Web (URL)", "Código HTML", "Proyecto Java", "Código C++", "Archivo .ZIP"};
        for (String op : opciones) {
            Button btn = new Button(this);
            btn.setText(op);
            btn.setOnClickListener(v -> {
                config.inputType = op;
                step++;
                mostrarPaso();
            });
            layout.addView(btn);
        }
    }

    private void renderAppDetails(LinearLayout layout) {
        EditText name = new EditText(this);
        name.setHint("Nombre de tu aplicación");
        layout.addView(name);

        Button next = new Button(this);
        next.setText("Continuar");
        next.setOnClickListener(v -> {
            config.appName = name.getText().toString();
            // Lógica para ir a GitHub o Dashboard
            finish();
        });
        layout.addView(next);
    }
}

