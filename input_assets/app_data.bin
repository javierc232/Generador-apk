    private void loadProjects() {
        projectsContainer.removeAllViews();
        try {
            JSONArray arr = new JSONArray(
                getSharedPreferences(PREFS, MODE_PRIVATE).getString(KEY_PROJ, "[]"));
            if (arr.length() == 0) { emptyState(); return; }
            for (int i = 0; i < arr.length(); i++) addCard(arr.getJSONObject(i));
        } catch (Exception e) { emptyState(); }
    }

    private void emptyState() {
        LinearLayout box = new LinearLayout(this);
        box.setOrientation(LinearLayout.VERTICAL);
        box.setGravity(Gravity.CENTER);
        box.setPadding(dp(32), dp(64), dp(32), dp(64));
        GradientDrawable bg = new GradientDrawable();
        bg.setColor(Color.parseColor("#161B22")); bg.setCornerRadius(dp(20));
        bg.setStroke(dp(1), Color.parseColor("#21262D"));
        box.setBackground(bg);

        TextView ic = new TextView(this);
        ic.setText("📦"); ic.setTextSize(52); ic.setGravity(Gravity.CENTER);
        box.addView(ic);

        TextView t = new TextView(this);
        t.setText("Sin proyectos aún");
        t.setTextSize(18); t.setTypeface(Typeface.DEFAULT_BOLD);
        t.setTextColor(Color.WHITE); t.setGravity(Gravity.CENTER);
        t.setPadding(0, dp(12), 0, dp(6));
        box.addView(t);

        TextView d = new TextView(this);
        d.setText("Toca «Nuevo Proyecto» para subir\ntus archivos y generar tu APK");
        d.setTextSize(13); d.setTextColor(Color.parseColor("#64748B"));
        d.setGravity(Gravity.CENTER);
        box.addView(d);
        projectsContainer.addView(box);
    }

    private void addCard(JSONObject p) {
        try {
            String id     = p.optString("id");
            String name   = p.optString("name", "Proyecto");
            String status = p.optString("status", "Pendiente");
            String color  = p.optString("color", "#4F6EF7");
            int    files  = p.optInt("fileCount", 0);
            boolean done  = status.equals("Completado");

            FrameLayout card = new FrameLayout(this);
            GradientDrawable cardBg = new GradientDrawable();
            cardBg.setColor(Color.parseColor("#161B22")); cardBg.setCornerRadius(dp(18));
            cardBg.setStroke(dp(1), done ? Color.parseColor("#1A3A2A") : Color.parseColor("#21262D"));
            card.setBackground(cardBg); card.setElevation(dp(6));
            LinearLayout.LayoutParams cLp = new LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
            cLp.setMargins(0, 0, 0, dp(12));
            card.setLayoutParams(cLp);

            // Barra de color top
            View bar = new View(this);
            GradientDrawable barBg = new GradientDrawable(GradientDrawable.Orientation.LEFT_RIGHT,
                new int[]{Color.parseColor(color), Color.parseColor(color + "33")});
            barBg.setCornerRadii(new float[]{dp(18),dp(18),dp(18),dp(18),0,0,0,0});
            bar.setBackground(barBg);
            bar.setLayoutParams(new FrameLayout.LayoutParams(FrameLayout.LayoutParams.MATCH_PARENT, dp(4)));
            card.addView(bar);

            LinearLayout inner = new LinearLayout(this);
            inner.setOrientation(LinearLayout.VERTICAL);
            inner.setPadding(dp(16), dp(16), dp(16), dp(14));
            FrameLayout.LayoutParams iLp = new FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, FrameLayout.LayoutParams.WRAP_CONTENT);
            iLp.topMargin = dp(4); inner.setLayoutParams(iLp);

            // Nombre + menú
            LinearLayout r1 = new LinearLayout(this);
            r1.setOrientation(LinearLayout.HORIZONTAL); r1.setGravity(Gravity.CENTER_VERTICAL);
            TextView tvN = new TextView(this);
            tvN.setText(name); tvN.setTextSize(17); tvN.setTypeface(Typeface.DEFAULT_BOLD);
            tvN.setTextColor(Color.WHITE);
            tvN.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
            r1.addView(tvN);
            TextView tvM = new TextView(this);
            tvM.setText("⋮"); tvM.setTextSize(20); tvM.setTextColor(Color.parseColor("#64748B"));
            tvM.setPadding(dp(12), 0, 0, 0);
            tvM.setOnClickListener(v -> menu(id, name));
            r1.addView(tvM); inner.addView(r1);

            // Info + badge
            LinearLayout r2 = new LinearLayout(this);
            r2.setOrientation(LinearLayout.HORIZONTAL); r2.setGravity(Gravity.CENTER_VERTICAL);
            r2.setPadding(0, dp(8), 0, 0);
            TextView tvF = new TextView(this);
            tvF.setText("📎 " + files + " archivo" + (files == 1 ? "" : "s"));
            tvF.setTextSize(12); tvF.setTextColor(Color.parseColor("#64748B"));
            tvF.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
            r2.addView(tvF);
            TextView badge = new TextView(this);
            badge.setText(done ? "✓ Listo" : "⏳ " + status);
            badge.setTextSize(11); badge.setTypeface(Typeface.DEFAULT_BOLD);
            badge.setTextColor(done ? Color.parseColor("#22C55E") : Color.parseColor("#F59E0B"));
            badge.setPadding(dp(10), dp(4), dp(10), dp(4));
            GradientDrawable bdg = new GradientDrawable();
            bdg.setColor(done ? Color.parseColor("#0F2A1A") : Color.parseColor("#2A1F0A"));
            bdg.setCornerRadius(dp(20)); badge.setBackground(bdg);
            r2.addView(badge); inner.addView(r2);

            card.addView(inner);
            projectsContainer.addView(card);
        } catch (Exception ignored) {}
    }

    private void menu(String id, String name) {
        new AlertDialog.Builder(this)
            .setTitle(name)
            .setItems(new String[]{"📥 Descargar APK","🔗 Ver GitHub Actions","➕ Agregar archivos","🗑 Eliminar"}, (d, w) -> {
                switch (w) {
                    case 0: case 1:
                        startActivity(new Intent(Intent.ACTION_VIEW, Uri.parse("https://github.com/javierc232/Generador-apk/actions")));
                        break;
                    case 2:
                        Intent i = new Intent(this, BuilderActivity.class);
                        i.putExtra("project_id", id); startActivity(i); break;
                    case 3: confirmDelete(id); break;
                }
            }).show();
    }

    private void confirmDelete(String id) {
        new AlertDialog.Builder(this).setTitle("¿Eliminar?")
            .setMessage("Esta acción no se puede deshacer.")
            .setPositiveButton("Eliminar", (d, w) -> {
                try {
                    SharedPreferences sp = getSharedPreferences(PREFS, MODE_PRIVATE);
                    JSONArray a = new JSONArray(sp.getString(KEY_PROJ, "[]"));
                    JSONArray n = new JSONArray();
                    for (int i = 0; i < a.length(); i++)
                        if (!a.getJSONObject(i).optString("id").equals(id)) n.put(a.getJSONObject(i));
                    sp.edit().putString(KEY_PROJ, n.toString()).apply();
                    loadProjects();
                } catch (Exception ignored) {}
            }).setNegativeButton("Cancelar", null).show();
    }

    // ── Permisos ──────────────────────────────────────────────────────────────
    private void handleNew() {
        SharedPreferences sp = getSharedPreferences(PREFS, MODE_PRIVATE);
        if (sp.getBoolean(KEY_PERMS, false) || permsOk()) {
            sp.edit().putBoolean(KEY_PERMS, true).apply();
            startActivity(new Intent(this, BuilderActivity.class));
        } else {
            new AlertDialog.Builder(this).setTitle("Permisos necesarios")
                .setMessage("Necesitamos acceso a tus archivos para leer .java, .xml, .gradle, imágenes y ZIPs.\n\nSolo se pedirá una vez.")
                .setPositiveButton("Continuar", (d, w) -> askPerms())
                .setNegativeButton("Cancelar", null).show();
        }
    }

    private boolean permsOk() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R && !Environment.isExternalStorageManager()) return false;
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU)
            return ContextCompat.checkSelfPermission(this, Manifest.permission.READ_MEDIA_IMAGES) == PackageManager.PERMISSION_GRANTED;
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M)
            return ContextCompat.checkSelfPermission(this, Manifest.permission.READ_EXTERNAL_STORAGE) == PackageManager.PERMISSION_GRANTED;
        return true;
    }

    private void askPerms() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.R) {
            try { startActivityForResult(new Intent(Settings.ACTION_MANAGE_APP_ALL_FILES_ACCESS_PERMISSION, Uri.parse("package:" + getPackageName())), REQ_MANAGE); }
            catch (Exception e) { startActivityForResult(new Intent(Settings.ACTION_MANAGE_ALL_FILES_ACCESS_PERMISSION), REQ_MANAGE); }
        } else if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU)
            ActivityCompat.requestPermissions(this, new String[]{Manifest.permission.READ_MEDIA_IMAGES}, REQ_MEDIA);
        else
            ActivityCompat.requestPermissions(this, new String[]{Manifest.permission.READ_EXTERNAL_STORAGE, Manifest.permission.WRITE_EXTERNAL_STORAGE}, REQ_LEGACY);
    }

    @Override protected void onActivityResult(int req, int res, Intent data) {
        super.onActivityResult(req, res, data);
        if (req == REQ_MANAGE) {
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU)
                ActivityCompat.requestPermissions(this, new String[]{Manifest.permission.READ_MEDIA_IMAGES}, REQ_MEDIA);
            else donePerms();
        }
    }

    @Override public void onRequestPermissionsResult(int req, @NonNull String[] p, @NonNull int[] r) {
        super.onRequestPermissionsResult(req, p, r);
        if (req == REQ_MEDIA || req == REQ_LEGACY) donePerms();
    }

    private void donePerms() {
        getSharedPreferences(PREFS, MODE_PRIVATE).edit().putBoolean(KEY_PERMS, true).apply();
        startActivity(new Intent(this, BuilderActivity.class));
    }

    private int dp(int v) { return (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, v, getResources().getDisplayMetrics()); }
}

// ═════════════════════════════════════════════════════════════════════════════
//  BUILDER ACTIVITY — gestor de múltiples archivos + configuración + envío
// ═════════════════════════════════════════════════════════════════════════════
class BuilderActivity extends AppCompatActivity {

    private static final int REQ_FILES = 3001;
    private static final int REQ_ZIP   = 3002;
    private static final int REQ_ICON  = 3003;
    private static final String PREFS  = "wf_prefs";
    private static final String KEY_PROJ = "saved_projects";

    private final List<ProjectFile> files = new ArrayList<>();
    private String iconPath  = "";
    private String projectId = "";
    private String themeColor = "#4F6EF7";

    private LinearLayout filesContainer;
    private TextView tvCount;
    private ImageView ivIcon;
    private EditText etName, etPkg, etVer;

    @Override protected void onCreate(Bundle s) {
        super.onCreate(s);
        projectId = getIntent().getStringExtra("project_id");
        if (projectId == null || projectId.isEmpty()) projectId = UUID.randomUUID().toString();
        buildUI();
    }

    private void buildUI() {
        FrameLayout root = new FrameLayout(this);
        root.setBackgroundColor(Color.parseColor("#0D1117"));

        ScrollView sv = new ScrollView(this);
        LinearLayout main = new LinearLayout(this);
        main.setOrientation(LinearLayout.VERTICAL);
        main.setPadding(dp(20), dp(52), dp(20), dp(110));

        // Header con botón atrás
        LinearLayout hdr = new LinearLayout(this);
        hdr.setOrientation(LinearLayout.HORIZONTAL); hdr.setGravity(Gravity.CENTER_VERTICAL);
        hdr.setPadding(0, 0, 0, dp(24));
        TextView btnBack = new TextView(this);
        btnBack.setText("←"); btnBack.setTextSize(22); btnBack.setTextColor(Color.parseColor("#4F6EF7"));
        btnBack.setPadding(0, 0, dp(14), 0); btnBack.setOnClickListener(v -> finish());
        hdr.addView(btnBack);
        TextView hTitle = new TextView(this);
        hTitle.setText("Nuevo Proyecto"); hTitle.setTextSize(24);
        hTitle.setTypeface(Typeface.DEFAULT_BOLD); hTitle.setTextColor(Color.WHITE);
        hdr.addView(hTitle);
        main.addView(hdr);

        // ── Sección archivos ──────────────────────────────────────────────────
        main.addView(secLabel("📂  Archivos del proyecto"));

        // Dos botones: varios archivos | un ZIP
        LinearLayout btnRow = new LinearLayout(this);
        btnRow.setOrientation(LinearLayout.HORIZONTAL);
        btnRow.setPadding(0, 0, 0, dp(14));

        View bMulti = uploadBtn(
            "Seleccionar archivos",
            "☕.java  📄.xml  🔧.gradle\n🖼 imágenes  📎 otros",
            () -> {
                Intent i = new Intent(Intent.ACTION_GET_CONTENT);
                i.setType("*/*");
                i.putExtra(Intent.EXTRA_ALLOW_MULTIPLE, true);
                startActivityForResult(Intent.createChooser(i, "Seleccionar archivos"), REQ_FILES);
            }
        );
        LinearLayout.LayoutParams bLp1 = new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f);
        bLp1.setMargins(0, 0, dp(8), 0); bMulti.setLayoutParams(bLp1);
        btnRow.addView(bMulti);

        View bZip = uploadBtn(
            "Subir ZIP",
            "📦 Todo el proyecto\nen un archivo",
            () -> {
                Intent i = new Intent(Intent.ACTION_GET_CONTENT);
                i.setType("application/zip");
                startActivityForResult(Intent.createChooser(i, "Seleccionar ZIP"), REQ_ZIP);
            }
        );
        bZip.setLayoutParams(new LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f));
        btnRow.addView(bZip);
        main.addView(btnRow);

        // Lista de archivos
        filesContainer = new LinearLayout(this);
        filesContainer.setOrientation(LinearLayout.VERTICAL);
        main.addView(filesContainer);

        tvCount = new TextView(this);
        tvCount.setTextSize(12); tvCount.setTextColor(Color.parseColor("#64748B"));
        tvCount.setPadding(0, dp(4), 0, dp(16));
        main.addView(tvCount);
        refreshFiles();

        // ── Sección ícono ─────────────────────────────────────────────────────
        main.addView(secLabel("🖼  Ícono de la app"));

        LinearLayout iconRow = new LinearLayout(this);
